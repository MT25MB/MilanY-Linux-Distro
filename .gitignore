# milanY Linux Distribution
# .gitignore file

# Build artifacts
*.iso
*.img
*.tar.gz
*.tar.xz
*.zip

# Build directories
rootfs/
build/
BUILD/
WORK_DIR/
ISO_DIR/
cache/

# Temporary files
/tmp/milany-*/
/tmp/tmp.*/
*.tmp
*.temp

# Log files
*.log
logs/
var/log/milany-*/
/var/log/milany-*/

# Cache directories
cache/
var/cache/milany-*/
/var/cache/milany-*/
var/lib/milany-*/
/var/lib/milany-*/

# User data and sensitive files
*.key
*.pem
*.crt
*.p12
*.gpg
*.asc
*.pgp
id_rsa*
id_ecdsa*
id_ed25519*

# Configuration files with user data
*.conf
*.config
etc/milany/milany.conf
home/.config/milany/

# AI and API data
*.api
*.token
api_keys.txt
secrets.txt

# Network and security data
*.pcap
*.dump
firewall.rules
iptables.rules

# Privacy and audit data
audit-*.log
privacy-*.log
threat-*.log
scores-*.log

# Wallpaper and visualizer cache
wallpapers/cache/
visualizer/cache/
widgets/cache/
overlay/cache/
soundscape/cache/

# Editor and IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Package manager files
*.deb
*.rpm
*.pkg
*.tar

# Kernel and boot files
*.ko
*.img
vmlinuz*
initrd*
boot/grub/grub.cfg

# Documentation build
docs/_build/
*.aux
*.toc
*.out

# Test files
test-results/
coverage/
.nyc_output

# Node.js (if any web components)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python (if any Python components)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/

# Ruby (if any Ruby components)
Gemfile.lock
.bundle/

# Go (if any Go components)
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.prof

# Rust (if any Rust components
target/
Cargo.lock

# Backup files
*.bak
*.backup
*.old

# Compressed files
*.7z
*.dmg
*.gz
*.rar
*.sit
*.sitx
*.msi
*.msm
*.msp

# Database files
*.db
*.sqlite
*.sqlite3

# Certificate files
*.csr
*.crt
*.pem
*.key
*.p12
*.pfx

# SSH keys and configs
ssh_config
ssh_host_*
ssh_known_hosts

# GPG keys and data
gnupg/
*.gpg
*.asc
*.sig

# Tor data
tor/
.tor/

# VPN configs
*.ovpn
*.conf
*.p12

# Docker (if containerized)
.dockerignore
docker-compose.override.yml

# Kubernetes (if any k8s components)
*.kubeconfig

# Terraform (if any infra)
*.tfstate
*.tfstate.*
.terraform/

# Ansible (if any automation)
*.retry
inventory/

# Local development
.env.local
.env.development
.env.test
.env.production

# Performance profiling
*.prof
*.pprof

# Memory dumps
core
core.*
*.hprof
*.dump

# Lock files
*.lock
package-lock.json
yarn.lock
