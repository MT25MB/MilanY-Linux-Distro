#!/bin/bash
# milanY network scanner
# comprehensive network analysis tool

# colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m'

# default values
TARGET=""
PORT_RANGE="1-1000"
SCAN_TYPE="fast"
OUTPUT_FILE=""
VERBOSE=false

# help function
show_help() {
    echo -e "${CYAN}milany-scan - network security scanner${NC}"
    echo ""
    echo "usage: milany-scan [options] <target>"
    echo ""
    echo "options:"
    echo "  -t, --type <type>     scan type: fast, full, stealth, vuln"
    echo "  -p, --ports <range>   port range (default: 1-1000)"
    echo "  -o, --output <file>   save results to file"
    echo "  -v, --verbose         verbose output"
    echo "  -h, --help            show this help"
    echo ""
    echo "scan types:"
    echo "  fast    - quick scan of common ports"
    echo "  full    - comprehensive port scan"
    echo "  stealth - stealthy scan with timing"
    echo "  vuln    - vulnerability assessment"
    echo ""
    echo "examples:"
    echo "  milany-scan 192.168.1.1"
    echo "  milany-scan -t full -p 1-65535 10.0.0.0/24"
    echo "  milany-scan -t vuln -o scan_results.txt target.com"
}

# parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        -t|--type)
            SCAN_TYPE="$2"
            shift 2
            ;;
        -p|--ports)
            PORT_RANGE="$2"
            shift 2
            ;;
        -o|--output)
            OUTPUT_FILE="$2"
            shift 2
            ;;
        -v|--verbose)
            VERBOSE=true
            shift
            ;;
        -h|--help)
            show_help
            exit 0
            ;;
        -*)
            echo -e "${RED}error: unknown option $1${NC}"
            show_help
            exit 1
            ;;
        *)
            TARGET="$1"
            shift
            ;;
    esac
done

# check target
if [ -z "$TARGET" ]; then
    echo -e "${RED}error: target required${NC}"
    show_help
    exit 1
fi

# check dependencies
if ! command -v nmap >/dev/null 2>&1; then
    echo -e "${RED}error: nmap not found${NC}"
    echo "install with: pacman -S nmap"
    exit 1
fi

# scan functions
fast_scan() {
    echo -e "${BLUE}performing fast scan on $TARGET${NC}"
    
    local nmap_cmd="nmap -sS -T4 --open -p $PORT_RANGE"
    
    if [ "$VERBOSE" = true ]; then
        nmap_cmd="$nmap_cmd -v"
    fi
    
    if [ -n "$OUTPUT_FILE" ]; then
        nmap_cmd="$nmap_cmd -oA $OUTPUT_FILE"
    fi
    
    $nmap_cmd "$TARGET"
}

full_scan() {
    echo -e "${BLUE}performing comprehensive scan on $TARGET${NC}"
    
    local nmap_cmd="nmap -sS -sV -O -T4 -p $PORT_RANGE"
    
    if [ "$VERBOSE" = true ]; then
        nmap_cmd="$nmap_cmd -v"
    fi
    
    if [ -n "$OUTPUT_FILE" ]; then
        nmap_cmd="$nmap_cmd -oA $OUTPUT_FILE"
    fi
    
    $nmap_cmd "$TARGET"
}

stealth_scan() {
    echo -e "${BLUE}performing stealth scan on $TARGET${NC}"
    
    local nmap_cmd="nmap -sS -T2 -f --randomize-hosts -p $PORT_RANGE"
    
    if [ "$VERBOSE" = true ]; then
        nmap_cmd="$nmap_cmd -v"
    fi
    
    if [ -n "$OUTPUT_FILE" ]; then
        nmap_cmd="$nmap_cmd -oA $OUTPUT_FILE"
    fi
    
    $nmap_cmd "$TARGET"
}

vuln_scan() {
    echo -e "${BLUE}performing vulnerability scan on $TARGET${NC}"
    
    local nmap_cmd="nmap -sV --script vuln -T4 -p $PORT_RANGE"
    
    if [ "$VERBOSE" = true ]; then
        nmap_cmd="$nmap_cmd -v"
    fi
    
    if [ -n "$OUTPUT_FILE" ]; then
        nmap_cmd="$nmap_cmd -oA $OUTPUT_FILE"
    fi
    
    $nmap_cmd "$TARGET"
}

# additional analysis
analyze_results() {
    if [ -n "$OUTPUT_FILE" ] && [ -f "${OUTPUT_FILE}.nmap" ]; then
        echo -e "${CYAN}analyzing scan results...${NC}"
        
        # extract open ports
        local open_ports=$(grep "open" "${OUTPUT_FILE}.nmap" | awk '{print $1}' | cut -d'/' -f1 | sort -n | tr '\n' ',' | sed 's/,$//')
        
        if [ -n "$open_ports" ]; then
            echo -e "${GREEN}open ports: $open_ports${NC}"
            
            # check for common vulnerable services
            if echo "$open_ports" | grep -q "21"; then
                echo -e "${YELLOW}warning: ftp detected on port 21${NC}"
            fi
            
            if echo "$open_ports" | grep -q "23"; then
                echo -e "${RED}warning: telnet detected on port 23 (insecure)${NC}"
            fi
            
            if echo "$open_ports" | grep -q "3389"; then
                echo -e "${YELLOW}warning: rdp detected on port 3389${NC}"
            fi
        fi
    fi
}

# main execution
main() {
    echo -e "${GREEN}milany-scan starting...${NC}"
    echo -e "${CYAN}target: $TARGET${NC}"
    echo -e "${CYAN}scan type: $SCAN_TYPE${NC}"
    echo -e "${CYAN}port range: $PORT_RANGE${NC}"
    echo ""
    
    # check if target is reachable
    if ! ping -c 1 -W 2 "$TARGET" >/dev/null 2>&1; then
        echo -e "${YELLOW}warning: target may not be reachable${NC}"
    fi
    
    # perform scan
    case "$SCAN_TYPE" in
        fast)
            fast_scan
            ;;
        full)
            full_scan
            ;;
        stealth)
            stealth_scan
            ;;
        vuln)
            vuln_scan
            ;;
        *)
            echo -e "${RED}error: invalid scan type${NC}"
            show_help
            exit 1
            ;;
    esac
    
    # analyze results
    analyze_results
    
    echo ""
    echo -e "${GREEN}scan complete${NC}"
    
    if [ -n "$OUTPUT_FILE" ]; then
        echo -e "${CYAN}results saved to: ${OUTPUT_FILE}.nmap${NC}"
    fi
}

# handle signals
trap 'echo -e "${YELLOW}scan interrupted${NC}"; exit 1' SIGINT SIGTERM

# run main function
main "$@"
