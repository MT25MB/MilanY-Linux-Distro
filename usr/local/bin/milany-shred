#!/bin/bash
# milanY secure file shredder
# multi-pass secure deletion utility

RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
WHITE='\033[1;37m'
NC='\033[0m'

VAULT_DIR="/var/lib/milany-shred"
LOG_FILE="/var/log/milany-shred.log"

show_help() {
    echo -e "${CYAN}milanY secure shredder${NC}"
    echo ""
    echo "usage: milany-shred [options] <file|directory>"
    echo ""
    echo "options:"
    echo "  -n, --passes <n>   number of overwrite passes (default: 3)"
    echo "  -f, --fast        fast mode (1 pass with random data)"
    echo "  -d, --dod         DoD 5220.22-M standard (7 passes)"
    echo "  -g, --guttman     Gutmann method (35 passes)"
    echo "  -z, --zero        add zero pass after overwriting"
    echo "  -r, --recursive   shred directories recursively"
    echo "  -v, --verbose     show detailed progress"
    echo "  -u, --unlink      remove file after shredding"
    echo "  -F, --freespace   wipe free disk space"
    echo "  -h, --help        show this help"
    echo ""
    echo "pass methods:"
    echo "  fast      - 1 pass (fast, basic security)"
    echo "  default   - 3 passes (recommended)"
    echo "  dod       - 7 passes (DoD standard)"
    echo "  gutmann   - 35 passes (maximum security)"
    echo ""
    echo "examples:"
    echo "  milany-shred -v -u sensitive.txt"
    echo "  milany-shred -d -r /path/to/directory"
    echo "  milany-shred -F /home"
}

log_message() {
    local level="$1"
    local message="$2"
    echo "$(date '+%Y-%m-%d %H:%M:%S') [$level] $message" >> "$LOG_FILE"
}

get_pass_method() {
    local method="$1"
    case "$method" in
        fast) echo 1 ;;
        dod) echo 7 ;;
        gutmann) echo 35 ;;
        *) echo 3 ;;
    esac
}

get_pattern() {
    local pass="$1"
    local total="$2"
    case "$pass" in
        1) echo "random" ;;
        2) echo "0x00" ;;
        3) echo "0xFF" ;;
        4) echo "0xAA" ;;
        5) echo "0x55" ;;
        6) echo "0x92" ;;
        7) echo "random" ;;
        *) echo "random" ;;
    esac
}

shred_file() {
    local file="$1"
    local passes="$2"
    local add_zero="$3"
    local verbose="$4"
    local unlink_after="$5"

    if [ ! -e "$file" ]; then
        echo -e "${RED}error: file not found: $file${NC}"
        return 1
    fi

    if [ -L "$file" ]; then
        echo -e "${YELLOW}skipping symbolic link: $file${NC}"
        return 0
    fi

    local file_size=$(stat -c %s "$file" 2>/dev/null || echo "0")
    local filename=$(basename "$file")

    echo -e "${BLUE}shredding: $file${NC}"
    [ "$verbose" = true ] && echo -e "${CYAN}size: $file_size bytes, passes: $passes${NC}"

    for ((i=1; i<=passes; i++)); do
        local pattern=$(get_pattern "$i" "$passes")

        if [ "$pattern" = "random" ]; then
            if [ -w "$file" ]; then
                dd if=/dev/urandom of="$file" bs=4096 count=$((file_size / 4096 + 1)) 2>/dev/null
            fi
            [ "$verbose" = true ] && echo -e "  pass $i/$passes: random data"
        else
            local byte_val=$(echo "$pattern" | sed 's/0x//')
            if [ -w "$file" ]; then
                printf "\\x${byte_val}" | dd of="$file" bs=1 seek=0 count=$file_size conv=notrunc 2>/dev/null
            fi
            [ "$verbose" = true ] && echo -e "  pass $i/$passes: $pattern"
        fi
    done

    if [ "$add_zero" = true ]; then
        if [ -w "$file" ]; then
            printf "\\x00" | dd of="$file" bs=1 seek=0 count=$file_size conv=notrunc 2>/dev/null
        fi
        [ "$verbose" = true ] && echo -e "  final pass: zeros"
    fi

    sync

    if [ "$unlink_after" = true ]; then
        rm -f "$file"
        [ "$verbose" = true ] && echo -e "${GREEN}file removed${NC}"
    fi

    echo -e "${GREEN}✓ shredded: $filename${NC}"
    log_message "INFO" "shredded: $file ($passes passes)"
}

shred_directory() {
    local dir="$1"
    local passes="$2"
    local add_zero="$3"
    local verbose="$4"
    local unlink_after="$5"

    if [ ! -d "$dir" ]; then
        echo -e "${RED}error: directory not found: $dir${NC}"
        return 1
    fi

    local count=0
    while IFS= read -r -d '' file; do
        shred_file "$file" "$passes" "$add_zero" "$verbose" "$unlink_after"
        count=$((count + 1))
    done < <(find "$dir" -type f -print0 2>/dev/null)

    echo -e "${GREEN}shredded $count files in $dir${NC}"
}

wipe_freespace() {
    local target="$1"
    local verbose="$2"

    echo -e "${YELLOW}wiping free space on $target (this may take a while)${NC}"

    local temp_file="$target/.milany_shred_$$"
    local file_size=$((1024 * 1024 * 500))

    local available=$(df -k "$target" | awk 'NR==2 {print $4}')
    local fill_size=$((available - 102400))

    if [ "$fill_size" -gt 0 ]; then
        if [ "$verbose" = true ]; then
            echo -e "${CYAN}filling $fill_size KB of free space${NC}"
        fi

        dd if=/dev/zero of="$temp_file" bs=1024 count=$fill_size 2>/dev/null
        sync
        rm -f "$temp_file"
        sync
    fi

    if [ "$verbose" = true ]; then
        echo -e "${CYAN}wiping inodes${NC}"
    fi

    local temp_dir="$target/.milany_shred_inodes_$$"
    mkdir -p "$temp_dir"

    for i in $(seq 1 100); do
        touch "$temp_dir/shred_$i" 2>/dev/null
    done

    rm -rf "$temp_dir"
    sync

    echo -e "${GREEN}free space wipe complete${NC}"
    log_message "INFO" "free space wiped on $target"
}

PASSES=3
VERBOSE=false
UNLINK=false
RECURSIVE=false
ADD_ZERO=false
FREESPACE=false

while [[ $# -gt 0 ]]; do
    case $1 in
        -n|--passes)
            PASSES="$2"
            shift 2
            ;;
        -f|--fast)
            PASSES=1
            shift
            ;;
        -d|--dod)
            PASSES=7
            shift
            ;;
        -g|--guttman)
            PASSES=35
            shift
            ;;
        -z|--zero)
            ADD_ZERO=true
            shift
            ;;
        -r|--recursive)
            RECURSIVE=true
            shift
            ;;
        -v|--verbose)
            VERBOSE=true
            shift
            ;;
        -u|--unlink)
            UNLINK=true
            shift
            ;;
        -F|--freespace)
            FREESPACE=true
            shift
            ;;
        -h|--help)
            show_help
            exit 0
            ;;
        *)
            TARGET="$1"
            shift
            ;;
    esac
done

mkdir -p "$(dirname "$LOG_FILE")"
touch "$LOG_FILE"

if [ "$FREESPACE" = true ]; then
    if [ -z "$TARGET" ]; then
        TARGET="/tmp"
    fi
    wipe_freespace "$TARGET" "$VERBOSE"
    exit 0
fi

if [ -z "$TARGET" ]; then
    echo -e "${RED}error: no file specified${NC}"
    show_help
    exit 1
fi

if [ "$RECURSIVE" = true ]; then
    shred_directory "$TARGET" "$PASSES" "$ADD_ZERO" "$VERBOSE" "$UNLINK"
else
    shred_file "$TARGET" "$PASSES" "$ADD_ZERO" "$VERBOSE" "$UNLINK"
fi