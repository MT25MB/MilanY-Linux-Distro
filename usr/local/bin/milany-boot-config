#!/bin/bash
# milanY boot configuration
# setup and configure boot animation and splash

# colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m'

# help function
show_help() {
    echo -e "${CYAN}milany-boot-config - boot configuration manager${NC}"
    echo ""
    echo "usage: milany-boot-config <command>"
    echo ""
    echo "commands:"
    echo "  install              install milanY boot theme"
    echo "  enable               enable boot splash"
    echo "  disable              disable boot splash"
    echo "  status               show current status"
    echo "  test                 test boot animation"
    echo "  update-grub          update grub configuration"
    echo ""
    echo "examples:"
    echo "  milany-boot-config install"
    echo "  milany-boot-config enable"
    echo "  milany-boot-config test"
}

# check root
check_root() {
    if [[ $EUID -ne 0 ]]; then
        echo -e "${RED}error: this script must be run as root${NC}"
        exit 1
    fi
}

# install boot theme
install_theme() {
    echo -e "${BLUE}installing milanY boot theme...${NC}"
    
    # check if plymouth is installed
    if ! command -v plymouth >/dev/null 2>&1; then
        echo -e "${YELLOW}installing plymouth...${NC}"
        pacman -S --noconfirm plymouth
    fi
    
    # create theme directory if not exists
    mkdir -p /usr/share/plymouth/themes/milany
    
    # copy theme files (they should already be in place)
    if [ -f /usr/share/plymouth/themes/milany/milany.plymouth ]; then
        echo -e "${GREEN}theme files found${NC}"
    else
        echo -e "${RED}error: theme files not found${NC}"
        exit 1
    fi
    
    # set as default theme
    plymouth-set-default-theme -R milany
    
    echo -e "${GREEN}milany boot theme installed${NC}"
}

# enable boot splash
enable_splash() {
    echo -e "${BLUE}enabling boot splash...${NC}"
    
    # update kernel parameters
    local grub_file="/etc/default/grub"
    
    if [ -f "$grub_file" ]; then
        # backup original
        cp "$grub_file" "$grub_file.backup"
        
        # add splash parameters
        sed -i 's/GRUB_CMDLINE_LINUX_DEFAULT="[^"]*/& splash quiet plymouth.ignore-serial-consoles/' "$grub_file"
        
        # update grub
        update-grub
        
        echo -e "${GREEN}boot splash enabled${NC}"
    else
        echo -e "${RED}error: grub config not found${NC}"
        exit 1
    fi
}

# disable boot splash
disable_splash() {
    echo -e "${BLUE}disabling boot splash...${NC}"
    
    local grub_file="/etc/default/grub"
    
    if [ -f "$grub_file" ]; then
        # remove splash parameters
        sed -i 's/splash quiet plymouth.ignore-serial-consoles//g' "$grub_file"
        sed -i 's/GRUB_CMDLINE_LINUX_DEFAULT=" *"/GRUB_CMDLINE_LINUX_DEFAULT=""/g' "$grub_file"
        
        # update grub
        update-grub
        
        echo -e "${GREEN}boot splash disabled${NC}"
    else
        echo -e "${RED}error: grub config not found${NC}"
        exit 1
    fi
}

# show status
show_status() {
    echo -e "${CYAN}[ BOOT STATUS ]${NC}"
    
    # check plymouth
    if command -v plymouth >/dev/null 2>&1; then
        echo -e "${WHITE}plymouth:${NC} ${GREEN}installed${NC}"
        
        local current_theme=$(plymouth-set-default-theme)
        echo -e "${WHITE}current theme:${NC} $current_theme"
    else
        echo -e "${WHITE}plymouth:${NC} ${RED}not installed${NC}"
    fi
    
    # check grub config
    local grub_file="/etc/default/grub"
    if [ -f "$grub_file" ]; then
        if grep -q "splash" "$grub_file"; then
            echo -e "${WHITE}boot splash:${NC} ${GREEN}enabled${NC}"
        else
            echo -e "${WHITE}boot splash:${NC} ${RED}disabled${NC}"
        fi
    fi
    
    # check initramfs
    if [ -f "/boot/initramfs-linux.img" ]; then
        echo -e "${WHITE}initramfs:${NC} ${GREEN}exists${NC}"
    else
        echo -e "${WHITE}initramfs:${NC} ${RED}missing${NC}"
    fi
}

# test boot animation
test_animation() {
    echo -e "${BLUE}testing boot animation...${NC}"
    
    if ! command -v plymouth >/dev/null 2>&1; then
        echo -e "${RED}error: plymouth not installed${NC}"
        exit 1
    fi
    
    # start plymouth daemon
    plymouthd --mode=boot --tty=tty7
    
    # show splash
    plymouth show-splash
    
    # simulate progress
    for i in {1..20}; do
        plymouth --update=$((i * 5))
        sleep 0.5
    done
    
    # quit after keypress
    echo -e "${CYAN}press any key to exit test${NC}"
    read -n 1
    
    plymouth quit
    
    echo -e "${GREEN}animation test complete${NC}"
}

# update grub
update_grub_config() {
    echo -e "${BLUE}updating grub configuration...${NC}"
    
    if command -v update-grub >/dev/null 2>&1; then
        update-grub
    elif command -v grub-mkconfig >/dev/null 2>&1; then
        grub-mkconfig -o /boot/grub/grub.cfg
    else
        echo -e "${RED}error: grub update command not found${NC}"
        exit 1
    fi
    
    echo -e "${GREEN}grub configuration updated${NC}"
}

# create boot logo
create_boot_logo() {
    echo -e "${BLUE}creating boot logo...${NC}"
    
    # create a simple text-based logo
    cat > /usr/share/plymouth/themes/milany/logo.txt << 'EOF'
 ____  _ _ _   ____      _    _     
|  _ \| (_) | |  _ \    / \  | |    
| |_) | | | | | | | |  / _ \ | |    
|  _ <| | | | | |_| | / ___ \| |___ 
|_| \_\_|_|_| |____(_)_/   \_\_____|
                                      
    privacy focused linux distro
EOF
    
    echo -e "${GREEN}boot logo created${NC}"
}

# main function
main() {
    if [ $# -lt 1 ]; then
        show_help
        exit 1
    fi
    
    local command="$1"
    
    case "$command" in
        install)
            check_root
            install_theme
            create_boot_logo
            ;;
        enable)
            check_root
            enable_splash
            ;;
        disable)
            check_root
            disable_splash
            ;;
        status)
            show_status
            ;;
        test)
            test_animation
            ;;
        update-grub)
            check_root
            update_grub_config
            ;;
        -h|--help)
            show_help
            ;;
        *)
            echo -e "${RED}error: unknown command${NC}"
            show_help
            exit 1
            ;;
    esac
}

# run main function
main "$@"
