#!/bin/bash
# milanY post-installation setup
# complete system configuration

# colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m'

# ascii art
cat << 'EOF'
 ____  _ _ _   ____      _    _     
|  _ \| (_) | |  _ \    / \  | |    
| |_) | | | | | | | |  / _ \ | |    
|  _ <| | | | | |_| | / ___ \| |___ 
|_| \_\_|_|_| |____(_)_/   \_\_____|
                                      
    post-installation setup utility
EOF

echo ""
echo -e "${CYAN}welcome to milanY setup${NC}"
echo -e "${CYAN}this will configure your system for optimal privacy and security${NC}"
echo ""

# check if running as user (not root)
if [[ $EUID -eq 0 ]]; then
    echo -e "${RED}error: run this as normal user, not root${NC}"
    exit 1
fi

# functions
setup_user() {
    echo -e "${BLUE}configuring user environment...${NC}"
    
    # copy dotfiles
    if [ -d /etc/skel ]; then
        cp -r /etc/skel/. ~/
        echo -e "${GREEN}dotfiles copied to home directory${NC}"
    fi
    
    # create directories
    mkdir -p ~/dev ~/docs ~/pics ~/vids ~/music ~/tmp
    chmod 700 ~/tmp
    echo -e "${GREEN}user directories created${NC}"
}

setup_desktop() {
    echo -e "${BLUE}configuring desktop environment...${NC}"
    
    # create .config directories
    mkdir -p ~/.config/i3 ~/.config/alacritty ~/.config/picom
    
    # copy i3 config
    if [ -f /usr/share/milany/i3config ]; then
        cp /usr/share/milany/i3config ~/.config/i3/config
        echo -e "${GREEN}i3 configuration installed${NC}"
    fi
    
    # copy alacritty config
    if [ -f /usr/share/milany/alacritty.yml ]; then
        cp /usr/share/milany/alacritty.yml ~/.config/alacritty/
        echo -e "${GREEN}alacritty configuration installed${NC}"
    fi
    
    # copy picom config
    if [ -f /usr/share/milany/picom.conf ]; then
        cp /usr/share/milany/picom.conf ~/.config/picom/
        echo -e "${GREEN}picom configuration installed${NC}"
    fi
}

setup_services() {
    echo -e "${BLUE}configuring system services...${NC}"
    
    # enable user services (requires sudo)
    echo -e "${YELLOW}enabling system services (requires sudo)${NC}"
    
    sudo systemctl enable NetworkManager
    sudo systemctl enable systemd-timesyncd
    
    # privacy services
    if [ -f /usr/local/bin/milany-privacy-init ]; then
        sudo systemctl enable milany-privacy.service
        echo -e "${GREEN}privacy service enabled${NC}"
    fi
    
    # wallpaper service
    if [ -f /usr/local/bin/milany-wallpaper ]; then
        sudo systemctl enable milany-wallpaper.service
        echo -e "${GREEN}wallpaper service enabled${NC}"
    fi
}

setup_firewall() {
    echo -e "${BLUE}configuring firewall...${NC}"
    
    # check if iptables rules exist
    if [ ! -f /etc/iptables/iptables.rules ]; then
        echo -e "${YELLOW}creating firewall rules (requires sudo)${NC}"
        sudo /usr/local/bin/milany-privacy-init
    fi
    
    echo -e "${GREEN}firewall configured${NC}"
}

setup_tor() {
    echo -e "${BLUE}configuring tor...${NC}"
    
    # check if tor is installed
    if command -v tor >/dev/null 2>&1; then
        echo -e "${YELLOW}configuring tor (requires sudo)${NC}"
        sudo systemctl enable tor
        echo -e "${GREEN}tor service enabled${NC}"
        echo -e "${CYAN}start with: milany-proxy tor start${NC}"
    else
        echo -e "${YELLOW}tor not installed - install with: sudo pacman -S tor${NC}"
    fi
}

setup_dnscrypt() {
    echo -e "${BLUE}configuring dnscrypt-proxy...${NC}"
    
    # check if dnscrypt is installed
    if command -v dnscrypt-proxy >/dev/null 2>&1; then
        echo -e "${YELLOW}configuring dnscrypt-proxy (requires sudo)${NC}"
        sudo systemctl enable dnscrypt-proxy
        echo -e "${GREEN}dnscrypt-proxy service enabled${NC}"
    else
        echo -e "${YELLOW}dnscrypt-proxy not installed - install with: sudo pacman -S dnscrypt-proxy${NC}"
    fi
}

setup_boot_theme() {
    echo -e "${BLUE}configuring boot theme...${NC}"
    
    if [ -f /usr/local/bin/milany-boot-config ]; then
        echo -e "${YELLOW}installing boot theme (requires sudo)${NC}"
        sudo milany-boot-config install
        sudo milany-boot-config enable
        echo -e "${GREEN}boot theme installed${NC}"
    fi
}

setup_ai() {
    echo -e "${BLUE}configuring ai integration...${NC}"
    
    # check for gemini key
    if [ -f /etc/milany/milany.conf ]; then
        if grep -q "GEMINI_API_KEY=" /etc/milany/milany.conf; then
            echo -e "${CYAN}gemini api key found in config${NC}"
            echo -e "${CYAN}test with: milany-ai-assistant${NC}"
        else
            echo -e "${YELLOW}no gemini api key found${NC}"
            echo -e "${CYAN}add your key to /etc/milany/milany.conf${NC}"
            echo -e "${CYAN}get key from: https://makersuite.google.com/app/apikey${NC}"
        fi
    else
        echo -e "${YELLOW}milany config not found${NC}"
    fi
}

create_shortcuts() {
    echo -e "${BLUE}creating desktop shortcuts...${NC}"
    
    # create application menu entries
    mkdir -p ~/.local/share/applications
    
    # milanY dashboard
    cat > ~/.local/share/applications/milany-dashboard.desktop << EOF
[Desktop Entry]
Name=milanY Dashboard
Comment=System monitoring dashboard
Exec=alacritty -e milany-dashboard
Icon=utilities-system-monitor
Terminal=false
Type=Application
Categories=System;Monitor;
EOF

    # milanY ai assistant
    cat > ~/.local/share/applications/milany-ai.desktop << EOF
[Desktop Entry]
Name=milanY AI Assistant
Comment=Privacy and security AI assistant
Exec=alacritty -e milany-ai-assistant
Icon=assistant
Terminal=false
Type=Application
Categories=Utility;
EOF

    echo -e "${GREEN}desktop shortcuts created${NC}"
}

final_setup() {
    echo -e "${BLUE}performing final setup...${NC}"
    
    # reload systemd
    systemctl --user daemon-reload 2>/dev/null || true
    
    # set permissions
    chmod +x ~/.config/i3/config 2>/dev/null || true
    
    # create startup script
    cat > ~/.config/i3/startup.sh << 'EOF'
#!/bin/bash
# milanY i3 startup script

# wait for services
sleep 2

# start picom
picom --config ~/.config/picom/picom.conf &

# set wallpaper
nitrogen --restore &

# start conky if installed
if command -v conky >/dev/null 2>&1; then
    conky &
fi

# start milanY services
if [ -f /usr/local/bin/milany-wallpaper ]; then
    milany-wallpaper &
fi
EOF
    
    chmod +x ~/.config/i3/startup.sh
    
    echo -e "${GREEN}final setup complete${NC}"
}

show_completion() {
    echo ""
    echo -e "${GREEN}=== milanY setup complete ===${NC}"
    echo ""
    echo -e "${CYAN}your system is now configured for privacy and security${NC}"
    echo ""
    echo -e "${YELLOW}next steps:${NC}"
    echo "1. reboot your system to apply all changes"
    echo "2. run 'milany-dashboard' to monitor your system"
    echo "3. configure your gemini api key for ai features"
    echo "4. explore the security tools in /usr/local/bin/"
    echo ""
    echo -e "${CYAN}useful commands:${NC}"
    echo "  milany-dashboard          - system monitoring"
    echo "  milany-ai-assistant       - ai security assistant"
    echo "  milany-proxy tor start    - start tor"
    echo "  milany-scan <target>      - network scanner"
    echo "  milany-crypt encrypt <file> - encrypt files"
    echo "  milany-netmon realtime    - network monitoring"
    echo ""
    echo -e "${GREEN}welcome to the shadows${NC}"
}

# main setup process
main() {
    echo -e "${BLUE}starting milanY setup...${NC}"
    echo ""
    
    setup_user
    setup_desktop
    setup_services
    setup_firewall
    setup_tor
    setup_dnscrypt
    setup_boot_theme
    setup_ai
    create_shortcuts
    final_setup
    show_completion
}

# run setup
main "$@"
