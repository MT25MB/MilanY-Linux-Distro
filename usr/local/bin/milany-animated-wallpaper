#!/bin/bash
# milanY animated wallpaper system
# dynamic, animated wallpapers with themes

# colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
MAGENTA='\033[0;35m'
WHITE='\033[1;37m'
NC='\033[0m'

# wallpaper configuration
WALLPAPER_DIR="/var/lib/milany-wallpaper"
WALLPAPER_CONFIG="$WALLPAPER_DIR/config.json"
WALLPAPER_CACHE="$WALLPAPER_DIR/cache"

# help function
show_help() {
    echo -e "${CYAN}milany-animated-wallpaper - animated wallpaper system${NC}"
    echo ""
    echo "usage: milany-animated-wallpaper [command] [options]"
    echo ""
    echo "commands:"
    echo "  start                  start animated wallpaper"
    echo "  stop                   stop animated wallpaper"
    echo "  restart                restart animated wallpaper"
    echo "  theme <name>           set wallpaper theme"
    echo "  themes                 list available themes"
    echo "  create <name>          create custom theme"
    echo "  speed <fps>            set animation speed"
    echo "  transition <type>       set transition type"
    echo "  schedule               enable time-based themes"
    echo "  weather                enable weather-based themes"
    echo ""
    echo "themes:"
    echo "  matrix                 matrix rain animation"
    echo "  cyberpunk              neon grid animation"
    echo "  ocean                  animated ocean waves"
    echo "  space                  starfield animation"
    echo "  fractal                animated fractals"
    echo "  glitch                 digital glitch effect"
    echo "  aurora                 northern lights effect"
    echo "  dna                    dna helix animation"
    echo ""
    echo "transitions:"
    echo "  fade                   smooth fade transition"
    echo "  slide                  slide transition"
    echo "  zoom                   zoom transition"
    echo "  glitch                 glitch transition"
    echo ""
    echo "examples:"
    echo "  milany-animated-wallpaper start"
    echo "  milany-animated-wallpaper theme matrix"
    echo "  milany-animated-wallpaper speed 30"
}

# initialize wallpaper system
init_wallpaper() {
    mkdir -p "$WALLPAPER_DIR"
    mkdir -p "$WALLPAPER_CACHE"
    
    # create default config
    if [ ! -f "$WALLPAPER_CONFIG" ]; then
        cat > "$WALLPAPER_CONFIG" << 'EOF'
{
    "theme": "matrix",
    "speed": 24,
    "transition": "fade",
    "schedule_enabled": false,
    "weather_enabled": false,
    "resolution": "1920x1080",
    "colors": {
        "primary": "#9b59b6",
        "secondary": "#3498db",
        "accent": "#e74c3c",
        "background": "#0a0a0f"
    }
}
EOF
    fi
}

# matrix rain wallpaper
matrix_wallpaper() {
    local width=${1:-1920}
    local height=${2:-1080}
    local output_dir="$WALLPAPER_CACHE/matrix"
    
    mkdir -p "$output_dir"
    
    local frame=0
    while true; do
        # create frame using imagemagick
        convert -size "${width}x${height}" xc:"#000000" \
            -font "Courier-Bold" -pointsize 14 -fill "#00ff00" \
            -gravity northwest \
            -annotate +0+0 "$(date '+%H:%M:%S')" \
            -gravity center \
            -annotate +0+0 "milY" \
            "$output_dir/frame_$(printf "%04d" $frame).png"
        
        # set as wallpaper
        if command -v feh >/dev/null 2>&1; then
            feh --bg-scale "$output_dir/frame_$(printf "%04d" $frame).png"
        elif command -v nitrogen >/dev/null 2>&1; then
            nitrogen --set-scaled "$output_dir/frame_$(printf "%04d" $frame).png"
        fi
        
        frame=$((frame + 1))
        sleep 0.04
    done
}

# cyberpunk grid wallpaper
cyberpunk_wallpaper() {
    local width=${1:-1920}
    local height=${2:-1080}
    local output_dir="$WALLPAPER_CACHE/cyberpunk"
    
    mkdir -p "$output_dir"
    
    local frame=0
    while true; do
        # create animated grid
        local time_offset=$(date +%s)
        local grid_offset=$((time_offset % 20))
        
        # create base image
        convert -size "${width}x${height}" xc:"#0a0a0f" \
            -stroke "#9b59b6" -strokewidth 1 \
            -draw "line $grid_offset,0 $grid_offset,$height" \
            "$output_dir/base.png"
        
        # add animated elements
        for ((i=0; i<5; i++)); do
            local x=$((width / 6 * (i + 1)))
            local y=$((height / 2 + (time_offset + i * 100) % 100 - 50))
            local size=$((20 + (time_offset + i * 50) % 30))
            
            convert "$output_dir/base.png" \
                -fill "#3498db" -draw "circle $x,$y $x,$((y - size))" \
                "$output_dir/frame_$(printf "%04d" $frame).png"
        done
        
        # set as wallpaper
        if command -v feh >/dev/null 2>&1; then
            feh --bg-scale "$output_dir/frame_$(printf "%04d" $frame).png"
        fi
        
        frame=$((frame + 1))
        sleep 0.05
    done
}

# ocean waves wallpaper
ocean_wallpaper() {
    local width=${1:-1920}
    local height=${2:-1080}
    local output_dir="$WALLPAPER_CACHE/ocean"
    
    mkdir -p "$output_dir"
    
    local frame=0
    while true; do
        local time_offset=$(date +%s)
        
        # create gradient background
        convert -size "${width}x${height}" \
            gradient:"#001122-#003366" \
            "$output_dir/gradient.png"
        
        # add animated waves
        for ((wave=0; wave<3; wave++)); do
            local wave_offset=$((time_offset + wave * 200))
            local wave_height=$((height / 2 + (wave_offset % 200 - 100) / 4))
            
            convert "$output_dir/gradient.png" \
                -stroke "#4488ff" -strokewidth 2 -fill "none" \
                -draw "polyline 0,$wave_height $width,$wave_height" \
                "$output_dir/frame_$(printf "%04d" $frame).png"
        done
        
        # add milanY logo
        convert "$output_dir/frame_$(printf "%04d" $frame).png" \
            -font "Arial-Bold" -pointsize 60 -fill "#ffffff" \
            -gravity center -annotate +0+0 "milanY" \
            "$output_dir/frame_$(printf "%04d" $frame).png"
        
        # set as wallpaper
        if command -v feh >/dev/null 2>&1; then
            feh --bg-scale "$output_dir/frame_$(printf "%04d" $frame).png"
        fi
        
        frame=$((frame + 1))
        sleep 0.08
    done
}

# starfield wallpaper
starfield_wallpaper() {
    local width=${1:-1920}
    local height=${2:-1080}
    local output_dir="$WALLPAPER_CACHE/starfield"
    
    mkdir -p "$output_dir"
    
    # generate star positions
    local star_count=200
    > "$output_dir/stars.txt"
    
    for ((i=0; i<star_count; i++)); do
        local star_x=$((RANDOM % width))
        local star_y=$((RANDOM % height))
        local star_size=$((1 + RANDOM % 3))
        local star_speed=$((1 + RANDOM % 5))
        echo "$star_x,$star_y,$star_size,$star_speed" >> "$output_dir/stars.txt"
    done
    
    local frame=0
    while true; do
        # create black background
        convert -size "${width}x${height}" xc:"#000000" \
            "$output_dir/frame_$(printf "%04d" $frame).png"
        
        # add moving stars
        while IFS=',' read -r star_x star_y star_size star_speed; do
            local new_x=$((star_x + frame * star_speed))
            if [ $new_x -ge $width ]; then
                new_x=$((new_x % width))
            fi
            
            local brightness=$((255 - frame % 50))
            local color="#$(printf "%02x" $brightness)$(printf "%02x" $brightness)$(printf "%02x" $brightness)"
            
            convert "$output_dir/frame_$(printf "%04d" $frame).png" \
                -fill "$color" -draw "circle $new_x,$star_y $new_x,$((star_y - star_size))" \
                "$output_dir/frame_$(printf "%04d" $frame).png"
        done < "$output_dir/stars.txt"
        
        # set as wallpaper
        if command -v feh >/dev/null 2>&1; then
            feh --bg-scale "$output_dir/frame_$(printf "%04d" $frame).png"
        fi
        
        frame=$((frame + 1))
        sleep 0.04
    done
}

# fractal animation wallpaper
fractal_wallpaper() {
    local width=${1:-1920}
    local height=${2:-1080}
    local output_dir="$WALLPAPER_CACHE/fractal"
    
    mkdir -p "$output_dir"
    
    local frame=0
    while true; do
        local zoom_factor=$(echo "scale=4; 1 + $frame * 0.01" | bc -l 2>/dev/null || echo "1")
        local rotation=$(($frame * 2))
        
        # create fractal using imagemagick
        convert -size "${width}x${height}" \
            -seed "$frame" \
            -virtual-pixel tile \
            -distort SRT "$zoom_factor,0,0,0,0,0,$rotation" \
            -modulate 100,100,110 \
            "$output_dir/frame_$(printf "%04d" $frame).png"
        
        # add milanY branding
        convert "$output_dir/frame_$(printf "%04d" $frame).png" \
            -font "Arial-Bold" -pointsize 40 -fill "#9b59b6" \
            -gravity southeast -annotate +20+20 "milanY" \
            "$output_dir/frame_$(printf "%04d" $frame).png"
        
        # set as wallpaper
        if command -v feh >/dev/null 2>&1; then
            feh --bg-scale "$output_dir/frame_$(printf "%04d" $frame).png"
        fi
        
        frame=$((frame + 1))
        sleep 0.1
    done
}

# glitch effect wallpaper
glitch_wallpaper() {
    local width=${1:-1920}
    local height=${2:-1080}
    local output_dir="$WALLPAPER_CACHE/glitch"
    
    mkdir -p "$output_dir"
    
    # create base image
    convert -size "${width}x${height}" xc:"#0a0a0f" \
        -font "Courier-Bold" -pointsize 80 -fill "#9b59b6" \
        -gravity center -annotate +0+0 "milanY" \
        "$output_dir/base.png"
    
    local frame=0
    while true; do
        local glitch_intensity=$((frame % 10))
        
        # apply random glitch effects
        case $glitch_intensity in
            0|1|2)
                # color channel shift
                convert "$output_dir/base.png" \
                    -channel R -level 0,100%,$((50 + RANDOM % 50))% \
                    "$output_dir/frame_$(printf "%04d" $frame).png"
                ;;
            3|4|5)
                # pixelation
                convert "$output_dir/base.png" \
                    -scale 10% -scale 1000% \
                    "$output_dir/frame_$(printf "%04d" $frame).png"
                ;;
            6|7)
                # scan lines
                convert "$output_dir/base.png" \
                    -define filter:filter=Box -define filter:width=1 -define filter:height=2 \
                    -filter Fourier \
                    "$output_dir/frame_$(printf "%04d" $frame).png"
                ;;
            *)
                # normal with noise
                convert "$output_dir/base.png" \
                    +noise Random \
                    "$output_dir/frame_$(printf "%04d" $frame).png"
                ;;
        esac
        
        # set as wallpaper
        if command -v feh >/dev/null 2>&1; then
            feh --bg-scale "$output_dir/frame_$(printf "%04d" $frame).png"
        fi
        
        frame=$((frame + 1))
        sleep 0.15
    done
}

# aurora effect wallpaper
aurora_wallpaper() {
    local width=${1:-1920}
    local height=${2:-1080}
    local output_dir="$WALLPAPER_CACHE/aurora"
    
    mkdir -p "$output_dir"
    
    local frame=0
    while true; do
        local time_offset=$(date +%s)
        
        # create gradient background
        convert -size "${width}x${height}" \
            gradient:"#001122-#002244" \
            "$output_dir/gradient.png"
        
        # add aurora waves
        for ((wave=0; wave<4; wave++)); do
            local wave_offset=$((time_offset + wave * 300))
            local wave_height=$((height / 3 + (wave_offset % 400 - 200) / 2))
            
            # aurora colors
            local colors=("#00ff88" "#00ffff" "#ff00ff" "#ffff00")
            local color=${colors[$wave]}
            
            convert "$output_dir/gradient.png" \
                -stroke "$color" -strokewidth 3 -fill "none" \
                -draw "polyline 0,$wave_height $width,$((wave_height + (wave_offset % 100 - 50)))" \
                "$output_dir/frame_$(printf "%04d" $frame).png"
        done
        
        # set as wallpaper
        if command -v feh >/dev/null 2>&1; then
            feh --bg-scale "$output_dir/frame_$(printf "%04d" $frame).png"
        fi
        
        frame=$((frame + 1))
        sleep 0.08
    done
}

# start animated wallpaper
start_wallpaper() {
    local theme=$(jq -r '.theme' "$WALLPAPER_CONFIG" 2>/dev/null || echo "matrix")
    local width=$(jq -r '.resolution' "$WALLPAPER_CONFIG" 2>/dev/null | cut -d'x' -f1 || echo "1920")
    local height=$(jq -r '.resolution' "$WALLPAPER_CONFIG" 2>/dev/null | cut -d'x' -f2 || echo "1080")
    
    echo -e "${BLUE}starting animated wallpaper: $theme${NC}"
    echo -e "${CYAN}press Ctrl+C to stop${NC}"
    
    case "$theme" in
        matrix)
            matrix_wallpaper "$width" "$height"
            ;;
        cyberpunk)
            cyberpunk_wallpaper "$width" "$height"
            ;;
        ocean)
            ocean_wallpaper "$width" "$height"
            ;;
        space)
            starfield_wallpaper "$width" "$height"
            ;;
        fractal)
            fractal_wallpaper "$width" "$height"
            ;;
        glitch)
            glitch_wallpaper "$width" "$height"
            ;;
        aurora)
            aurora_wallpaper "$width" "$height"
            ;;
        *)
            echo -e "${RED}error: unknown theme '$theme'${NC}"
            return 1
            ;;
    esac
}

# set wallpaper theme
set_theme() {
    local theme="$1"
    
    if [ -z "$theme" ]; then
        echo -e "${RED}error: theme required${NC}"
        return 1
    fi
    
    # update configuration
    local temp_config=$(mktemp)
    jq --arg theme "$theme" '.theme = $theme' "$WALLPAPER_CONFIG" > "$temp_config"
    mv "$temp_config" "$WALLPAPER_CONFIG"
    
    echo -e "${GREEN}wallpaper theme set to: $theme${NC}"
    
    # restart if running
    if pgrep -f "milany-animated-wallpaper" >/dev/null; then
        stop_wallpaper
        sleep 1
        start_wallpaper
    fi
}

# stop animated wallpaper
stop_wallpaper() {
    echo -e "${BLUE}stopping animated wallpaper...${NC}"
    
    # kill wallpaper process
    pkill -f "milany-animated-wallpaper" 2>/dev/null
    
    # restore static wallpaper
    if [ -f "/usr/share/milany/wallpapers/milany-main.png" ]; then
        if command -v feh >/dev/null 2>&1; then
            feh --bg-scale "/usr/share/milany/wallpapers/milany-main.png"
        elif command -v nitrogen >/dev/null 2>&1; then
            nitrogen --set-scaled "/usr/share/milany/wallpapers/milany-main.png"
        fi
    fi
    
    echo -e "${GREEN}animated wallpaper stopped${NC}"
}

# list available themes
list_themes() {
    echo -e "${CYAN}[ available themes ]${NC}"
    echo ""
    echo "  matrix     - classic matrix rain effect"
    echo "  cyberpunk  - neon grid with animations"
    echo "  ocean      - animated ocean waves"
    echo "  space      - moving starfield"
    echo "  fractal    - animated fractal zoom"
    echo "  glitch     - digital glitch effects"
    echo "  aurora     - northern lights simulation"
    echo ""
}

# main function
main() {
    init_wallpaper
    
    case "${1:-help}" in
        start)
            start_wallpaper
            ;;
        stop)
            stop_wallpaper
            ;;
        restart)
            stop_wallpaper
            sleep 1
            start_wallpaper
            ;;
        theme)
            set_theme "$2"
            ;;
        themes)
            list_themes
            ;;
        -h|--help)
            show_help
            ;;
        *)
            echo -e "${RED}error: unknown command${NC}"
            show_help
            exit 1
            ;;
    esac
}

# handle signals
trap 'stop_wallpaper; exit 0' SIGINT SIGTERM

# run main function
main "$@"
