#!/bin/bash
# milanY Tor Browser security wrapper
# configure Tor Browser for maximum anonymity

RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
MAGENTA='\033[0;35m'
WHITE='\033[1;37m'
NC='\033[0m'

CONFIG_DIR="/etc/milany/tor-browser"
TORRC="/etc/tor/torrc"
LOG_FILE="/var/log/milany-tor-browser.log"

show_help() {
    echo -e "${CYAN}milanY Tor Browser security wrapper${NC}"
    echo ""
    echo "usage: milany-tor-browser-hardener [command] [options]"
    echo ""
    echo "commands:"
    echo "  start              start Tor Browser with security settings"
    echo "  stop               stop Tor processes"
    echo "  status             show Tor status and connections"
    echo "  config             configure Tor settings"
    echo "  circuits           show Tor circuits"
    echo "  new-identity       request new Tor identity"
    echo "  isolation          configure circuit isolation"
    echo "  fingerprint        show browser fingerprint info"
    echo "  test-connection    test Tor connection"
    echo "  ports              show Tor port configuration"
    echo "  bridges            configure Tor bridges"
    echo ""
    echo "options:"
    echo "  -s, --security     security level (standard/safer/safest)"
    echo "  -v, --verbose      verbose output"
    echo "  -h, --help         show this help"
    echo ""
    echo "examples:"
    echo "  milany-tor-browser-hardener start"
    echo "  milany-tor-browser-hardener config --security safest"
    echo "  milany-tor-browser-hardener new-identity"
}

log_message() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') $1" >> "$LOG_FILE"
}

init_tor_config() {
    mkdir -p "$CONFIG_DIR"
    touch "$LOG_FILE"
}

check_tor() {
    if ! command -v tor >/dev/null 2>&1; then
        echo -e "${RED}tor not installed${NC}"
        echo "install with: pacman -S tor"
        return 1
    fi

    if ! systemctl is-active --quiet tor 2>/dev/null; then
        echo -e "${YELLOW}Tor service not running, starting...${NC}"
        systemctl start tor 2>/dev/null || echo -e "${YELLOW}Start tor manually: sudo systemctl start tor${NC}"
    fi
}

start_tor_browser() {
    local security="${1:-safest}"

    echo -e "${BLUE}starting Tor Browser with $security security${NC}"

    check_tor

    local tb_paths=(
        "/usr/bin/firefox"
        "/usr/bin/tor-browser"
        "/opt/tor-browser/Browser/firefox"
    )

    local browser=""
    for path in "${tb_paths[@]}"; do
        if [ -f "$path" ]; then
            browser="$path"
            break
        fi
    done

    if [ -z "$browser" ]; then
        echo -e "${YELLOW}Tor Browser not found, using system Firefox${NC}"
        browser="firefox"
    fi

    local profile_dir="$CONFIG_DIR/profile-$(date +%s)"

    mkdir -p "$profile_dir"

    cat > "$profile_dir/prefs.js" << EOF
user_pref("network.proxy.socks", "127.0.0.1");
user_pref("network.proxy.socks_port", 9050);
user_pref("network.proxy.type", 1);
user_pref("extensions.torbutton.current_country", "");
user_pref("extensions.torbutton.launch_torbrowser", true);
user_pref("extensions.torbutton.settings.loglevel", 2);
user_pref("browser.startup.homepage", "about:tor");
user_pref("security.tls.version.min", 1);
user_pref("security.tls.version.max", 3);
EOF

    case "$security" in
        standard)
            cat >> "$profile_dir/prefs.js" << 'EOF'
user_pref("privacy.resistFingerprinting", false);
user_pref("webgl.disabled", false);
user_pref("media.peerconnection.enabled", true);
user_pref("javascript.enabled", true);
EOF
            ;;
        safer)
            cat >> "$profile_dir/prefs.js" << 'EOF'
user_pref("privacy.resistFingerprinting", true);
user_pref("webgl.disabled", true);
user_pref("media.peerconnection.enabled", false);
user_pref("javascript.enabled", true);
EOF
            ;;
        safest)
            cat >> "$profile_dir/prefs.js" << 'EOF'
user_pref("privacy.resistFingerprinting", true);
user_pref("webgl.disabled", true);
user_pref("media.peerconnection.enabled", false);
user_pref("javascript.enabled", false);
user_pref("network.cookie.cookieBehavior", 1);
user_pref("privacy.trackingprotection.enabled", true);
EOF
            ;;
    esac

    echo -e "${GREEN}✓ configured profile with $security security${NC}"
    echo -e "${CYAN}starting browser...${NC}"

    if [ "$browser" = "firefox" ]; then
        firefox -P "$profile_dir" -no-remote &
    else
        "$browser" -P "$profile_dir" -no-remote &
    fi

    log_message "INFO" "started Tor Browser with $security security"
}

stop_tor_browser() {
    echo -e "${BLUE}stopping Tor Browser processes...${NC}"

    pkill -f "tor-browser" 2>/dev/null
    pkill -f "firefox.*tor" 2>/dev/null

    echo -e "${GREEN}✓ stopped${NC}"
}

show_status() {
    echo -e "${MAGENTA}=== Tor Status ===${NC}"
    echo ""

    if systemctl is-active --quiet tor 2>/dev/null; then
        echo -e "${GREEN}● Tor service: running${NC}"
    else
        echo -e "${RED}○ Tor service: not running${NC}"
    fi

    if pgrep -x tor >/dev/null 2>&1; then
        echo -e "${GREEN}● Tor process: running${NC}"
    else
        echo -e "${RED}○ Tor process: not running${NC}"
    fi

    echo ""

    if command -v ncat >/dev/null 2>&1; then
        local tor_version=$(echo -e "QUIT" | ncat 127.0.0.1 9051 2>/dev/null | head -1)
        if [ -n "$tor_version" ]; then
            echo -e "${CYAN}Tor version: $tor_version${NC}"
        fi
    fi

    if pgrep -x tor > /dev/null 2>&1; then
        echo ""
        echo -e "${CYAN}[ connections ]${NC}"
        curl -s --socks5 localhost:9050 https://check.torproject.org/api/ip 2>/dev/null | head -5 || echo "Cannot verify Tor connection"
    fi
}

configure_tor() {
    local security="$1"

    echo -e "${BLUE}configuring Tor settings${NC}"

    if [ ! -f "$TORRC.backup" ]; then
        cp "$TORRC" "$TORRC.backup" 2>/dev/null
    fi

    if ! grep -q "ControlPort 9051" "$TORRC"; then
        echo "ControlPort 9051" >> "$TORRC"
        echo "CookieAuthFile /var/run/tor/control.authcookie" >> "$TORRC"
    fi

    echo "AutomapHostsOnResolve 1" >> "$TORRC"
    echo "DNSPort 5353" >> "$TORRC"
    echo "TransPort 9040" >> "$TORRC"

    if [ "$security" = "hardened" ]; then
        echo "StrictNodes 1" >> "$TORRC"
        echo "ExcludeNodes {ru},{ua},{by},{kz},{cn},{ir},{sy}" >> "$TORRC"
        echo "ExcludeNodes {RU},{UA},{BY},{KZ},{CN},{IR},{SY}" >> "$TORRC"
        echo "ExcludeExitNodes {ru},{ua},{by},{kz},{cn},{ir},{sy}" >> "$TORRC"
    fi

    systemctl restart tor 2>/dev/null

    echo -e "${GREEN}✓ Tor configured${NC}"
    echo -e "${CYAN}DNS: 127.0.0.1:5353${NC}"
    echo -e "${CYAN}Transparent: 127.0.0.1:9040${NC}"
    echo -e "${CYAN}Control: 127.0.0.1:9051${NC}"
}

show_circuits() {
    if ! pgrep -x tor > /dev/null 2>&1; then
        echo -e "${RED}Tor not running${NC}"
        return 1
    fi

    echo -e "${BLUE}Tor circuits${NC}"
    echo ""

    if command -v arm >/dev/null 2>&1; then
        arm
    else
        echo -e "${YELLOW}arm not installed, using torctl${NC}"
        echo "To view circuits, install: pacman -S arm"
        echo ""
        echo "Current Tor version supports:torctl or nyx"
    fi
}

new_identity() {
    echo -e "${BLUE}requesting new Tor identity...${NC}"

    if command -v nyx >/dev/null 2>&1; then
        echo "Press 'n' in nyx for new identity"
    fi

    if [ -S /var/run/tor/control ]; then
        echo -e "AUTHENTICATE" | nc -U /var/run/tor/control 2>/dev/null
        echo "signal NEWNYM" | nc -U /var/run/tor/control 2>/dev/null
    fi

    if command -v stem >/dev/null 2>&1; then
        python3 << 'EOF'
from stem import Controller
from stem.control import Controller.from_port

try:
    controller = Controller.from_port(port=9051)
    controller.authenticate()
    controller.signal('NEWNYM')
    print("New identity requested")
except Exception as e:
    print(f"Error: {e}")
EOF
    fi

    echo -e "${GREEN}✓ new identity requested${NC}"
    log_message "INFO" "new Tor identity requested"
}

configure_isolation() {
    echo -e "${BLUE}configuring circuit isolation${NC}"
    echo ""

    cat > "$CONFIG_DIR/isolation.conf" << 'EOF'
# milanY Tor Browser Circuit Isolation
# Each website gets its own isolated circuit

# Enable stream isolation
SocksPort 9050
SocksPort 9052 Isolated
SocksPort 9053 Isolated

# Control port for programmatic control
ControlPort 9051
EOF

    echo -e "${GREEN}✓ isolation configured${NC}"
    echo -e "${CYAN}multiple SOCKS ports for isolation:${NC}"
    echo "  9050 - default"
    echo "  9052 - isolated stream 1"
    echo "  9053 - isolated stream 2"
}

show_fingerprint() {
    echo -e "${BLUE}browser fingerprint info${NC}"
    echo ""

    echo -e "${CYAN}[ User Agent ]${NC}"
    echo "Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:78.0) Gecko/20100101 Firefox/78.0"

    echo ""
    echo -e "${CYAN}[ Screen ]${NC}"
    echo "width: 1000, height: 800"
    echo "colorDepth: 24"

    echo ""
    echo -e "${CYAN}[ Timezone ]${NC}"
    echo "UTC"

    echo ""
    echo -e "${CYAN}[ Language ]${NC}"
    echo "en-US, en"

    echo ""
    echo -e "${YELLOW}To resist fingerprinting, use Tor Browser defaults${NC}"
    echo -e "${YELLOW}and avoid changing window size or installing extensions${NC}"
}

test_connection() {
    echo -e "${BLUE}testing Tor connection${NC}"
    echo ""

    if curl -s --socks5 localhost:9050 https://check.torproject.org/api/ip | grep -q "IsTor"; then
        echo -e "${GREEN}✓ Tor connection working${NC}"
        local ip=$(curl -s --socks5 localhost:9050 https://api.ipify.org)
        echo -e "${CYAN}Your IP: $ip${NC}"
    else
        echo -e "${RED}✗ Tor connection not working${NC}"
        echo "Check Tor status with: systemctl status tor"
    fi
}

show_ports() {
    echo -e "${CYAN}[ Tor Port Configuration ]${NC}"
    echo ""

    if [ -f "$TORRC" ]; then
        grep -E "^(SocksPort|ControlPort|DNSPort|TransPort)" "$TORRC" 2>/dev/null || echo "No ports configured"
    else
        echo "Torrc not found at $TORRC"
    fi

    echo ""
    echo -e "${CYAN}[ Active Ports ]${NC}"
    ss -tlnp | grep -E "(9050|9051|9040|5353)" 2>/dev/null || echo "No Tor ports listening"
}

configure_bridges() {
    local bridge_type="$1"

    echo -e "${BLUE}configuring Tor bridges${NC}"

    case "$bridge_type" in
        obfs4)
            echo "Bridge obfs4 80.71.178.130:9030 A00AC3CD09F03D76DDB7779D3BD7DBA50BF9DD37" >> "$TORRC"
            echo "Bridge obfs4 162.247.74.27:443 C73ADAA6F9C2C7E1A67B0E0F64B1C0DAD0B09A5" >> "$TORRC"
            ;;
        meek)
            echo "Bridge meek 0.0.2.0:2" >> "$TORRC"
            echo "UseBridges 1" >> "$TORRC"
            echo "ClientTransportPlugin meek_lite exec /usr/bin/meek-client" >> "$TORRC"
            ;;
        snowflake)
            echo "Bridge snowflake 192.0.2.3:80" >> "$TORRC"
            echo "UseBridges 1" >> "$TORRC"
            ;;
        *)
            echo -e "${YELLOW}bridge types: obfs4, meek, snowflake${NC}"
            echo -e "${CYAN}Adding default obfs4 bridges...${NC}"
            echo "Bridge obfs4 80.71.178.130:9030 A00AC3CD09F03D76DDB7779D3BD7DBA50BF9DD37" >> "$TORRC"
            ;;
    esac

    systemctl restart tor 2>/dev/null

    echo -e "${GREEN}✓ bridges configured${NC}"
    log_message "INFO" "configured $bridge_type bridges"
}

init_tor_config

case "${1:-help}" in
    start)
        start_tor_browser "$2"
        ;;
    stop)
        stop_tor_browser
        ;;
    status)
        show_status
        ;;
    config)
        configure_tor "$2"
        ;;
    circuits)
        show_circuits
        ;;
    new-identity)
        new_identity
        ;;
    isolation)
        configure_isolation
        ;;
    fingerprint)
        show_fingerprint
        ;;
    test-connection)
        test_connection
        ;;
    ports)
        show_ports
        ;;
    bridges)
        configure_bridges "$2"
        ;;
    -h|--help)
        show_help
        ;;
    *)
        show_help
        exit 1
        ;;
esac