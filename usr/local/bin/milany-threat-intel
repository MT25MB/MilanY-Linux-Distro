#!/bin/bash
# milanY threat intelligence feed
# real-time cybersecurity threat monitoring

# colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
MAGENTA='\033[0;35m'
WHITE='\033[1;37m'
NC='\033[0m'

# configuration
THREAT_FEED_DIR="/var/cache/milany-threat-intel"
THRESHOLD_DAYS=7
ALERT_FILE="/var/log/milany-threat-alerts.log"

# threat sources
declare -A THREAT_SOURCES=(
    ["cve"]="https://cve.circl.lu/api/cve/"
    ["virustotal"]="https://www.virustotal.com/vtapi/v2/"
    ["threatfox"]="https://threatfox.abuse.ch/api/"
    ["hybrid"]="https://hybrid-analysis.com/api/v2/"
)

# help function
show_help() {
    echo -e "${CYAN}milany-threat-intel - threat intelligence monitoring${NC}"
    echo ""
    echo "usage: milany-threat-intel [command] [options]"
    echo ""
    echo "commands:"
    echo "  update                 update threat intelligence feeds"
    echo "  scan <target>          scan target against threat database"
    echo "  alerts                 show recent threat alerts"
    echo "  monitor                start real-time monitoring"
    echo "  report                 generate threat report"
    echo "  search <term>         search threat database"
    echo "  stats                  show threat statistics"
    echo ""
    echo "options:"
    echo "  -d, --days <days>     lookback period (default: 7)"
    echo "  -s, --severity <level> filter by severity (low/medium/high/critical)"
    echo "  -t, --type <type>      filter by type (malware/vulnerability/phishing)"
    echo ""
    echo "examples:"
    echo "  milany-threat-intel update"
    echo "  milany-threat-intel scan 192.168.1.1"
    echo "  milany-threat-intel alerts --severity high"
}

# initialize directories
init_directories() {
    mkdir -p "$THREAT_FEED_DIR"
    mkdir -p "$(dirname "$ALERT_FILE")"
    touch "$ALERT_FILE"
}

# update threat feeds
update_feeds() {
    echo -e "${BLUE}updating threat intelligence feeds...${NC}"
    
    # update cve database
    echo -e "${CYAN}updating cve database...${NC}"
    curl -s "https://cve.circl.lu/api/last/" -o "$THREAT_FEED_DIR/cve_recent.json" 2>/dev/null
    
    # update malware signatures
    echo -e "${CYAN}updating malware signatures...${NC}"
    curl -s "https://raw.githubusercontent.com/Yara-Rules/rules/master/malware/index.yar" -o "$THREAT_FEED_DIR/malware.yar" 2>/dev/null
    
    # update phishing domains
    echo -e "${CYAN}updating phishing domains...${NC}"
    curl -s "https://raw.githubusercontent.com/mitchellkrogza/phishing-domains-list/master/domains/list.txt" -o "$THREAT_FEED_DIR/phishing_domains.txt" 2>/dev/null
    
    # update malicious ips
    echo -e "${CYAN}updating malicious ips...${NC}"
    curl -s "https://raw.githubusercontent.com/stamparm/ipsum/master/ipsum.txt" -o "$THREAT_FEED_DIR/malicious_ips.txt" 2>/dev/null
    
    echo -e "${GREEN}threat feeds updated${NC}"
    log_alert "info" "threat intelligence feeds updated"
}

# scan target against threat database
scan_target() {
    local target="$1"
    
    if [ -z "$target" ]; then
        echo -e "${RED}error: target required${NC}"
        return 1
    fi
    
    echo -e "${BLUE}scanning $target against threat database...${NC}"
    echo ""
    
    # check if target is ip or domain
    if [[ $target =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        scan_ip "$target"
    else
        scan_domain "$target"
    fi
}

# scan ip address
scan_ip() {
    local ip="$1"
    local threats_found=0
    
    echo -e "${CYAN}[ ip reputation check ]${NC}"
    
    # check against malicious ip list
    if [ -f "$THREAT_FEED_DIR/malicious_ips.txt" ]; then
        if grep -q "^$ip$" "$THREAT_FEED_DIR/malicious_ips.txt"; then
            echo -e "${RED}✗ ip found in malicious database${NC}"
            threats_found=$((threats_found + 1))
        else
            echo -e "${GREEN}✓ ip not in malicious database${NC}"
        fi
    fi
    
    # check recent cve for network services
    echo -e "${CYAN}[ network vulnerability check ]${NC}"
    if command -v nmap >/dev/null 2>&1; then
        local open_ports=$(nmap -sS -p- --min-rate=1000 "$ip" 2>/dev/null | grep "^ *[0-9]" | wc -l)
        if [ "$open_ports" -gt 0 ]; then
            echo -e "${YELLOW}⚠ $open_ports open ports detected${NC}"
        fi
    fi
    
    # geolocation check
    echo -e "${CYAN}[ geolocation check ]${NC}"
    local geo_info=$(curl -s "http://ip-api.com/json/$ip" 2>/dev/null)
    if [ -n "$geo_info" ]; then
        local country=$(echo "$geo_info" | jq -r '.country // "unknown"')
        local org=$(echo "$geo_info" | jq -r '.org // "unknown"')
        echo -e "${WHITE}location: $country ($org)${NC}"
    fi
    
    if [ $threats_found -gt 0 ]; then
        log_alert "warning" "malicious activity detected from $ip"
    fi
}

# scan domain
scan_domain() {
    local domain="$1"
    local threats_found=0
    
    echo -e "${CYAN}[ domain reputation check ]${NC}"
    
    # check against phishing domains
    if [ -f "$THREAT_FEED_DIR/phishing_domains.txt" ]; then
        if grep -q "$domain" "$THREAT_FEED_DIR/phishing_domains.txt"; then
            echo -e "${RED}✗ domain found in phishing database${NC}"
            threats_found=$((threats_found + 1))
        else
            echo -e "${GREEN}✓ domain not in phishing database${NC}"
        fi
    fi
    
    # dns resolution check
    echo -e "${CYAN}[ dns analysis ]${NC}"
    local ips=$(nslookup "$domain" 2>/dev/null | grep -A1 "Name:" | grep "Address:" | awk '{print $2}')
    if [ -n "$ips" ]; then
        echo -e "${WHITE}resolved ips: $ips${NC}"
        
        # scan each ip
        for ip in $ips; do
            scan_ip "$ip"
        done
    fi
    
    # ssl certificate check
    echo -e "${CYAN}[ ssl certificate check ]${NC}"
    if command -v openssl >/dev/null 2>&1; then
        local cert_info=$(echo | timeout 5 openssl s_client -connect "$domain:443" -servername "$domain" 2>/dev/null | openssl x509 -noout -text 2>/dev/null)
        if [ -n "$cert_info" ]; then
            local issuer=$(echo "$cert_info" | grep "Issuer:" | head -1 | cut -d: -f2 | sed 's/^ *//')
            echo -e "${WHITE}ssl issuer: $issuer${NC}"
        fi
    fi
    
    if [ $threats_found -gt 0 ]; then
        log_alert "warning" "malicious domain detected: $domain"
    fi
}

# show recent alerts
show_alerts() {
    local days="${1:-7}"
    local severity="${2:-all}"
    
    echo -e "${CYAN}[ recent threat alerts - last $days days ]${NC}"
    echo ""
    
    if [ ! -f "$ALERT_FILE" ]; then
        echo -e "${YELLOW}no threat alerts found${NC}"
        return
    fi
    
    # filter alerts by date
    local since_date=$(date -d "$days days ago" '+%Y-%m-%d')
    
    while IFS= read -r line; do
        local alert_date=$(echo "$line" | awk '{print $1}')
        local alert_time=$(echo "$line" | awk '{print $2}')
        local alert_level=$(echo "$line" | awk '{print $4}')
        local alert_msg=$(echo "$line" | cut -d' ' -f5-)
        
        # filter by severity
        if [ "$severity" != "all" ] && [ "$alert_level" != "$severity" ]; then
            continue
        fi
        
        # format output
        case "$alert_level" in
            "critical")
                echo -e "${RED}$alert_date $alert_time [CRITICAL] $alert_msg${NC}"
                ;;
            "high")
                echo -e "${RED}$alert_date $alert_time [HIGH] $alert_msg${NC}"
                ;;
            "medium")
                echo -e "${YELLOW}$alert_date $alert_time [MEDIUM] $alert_msg${NC}"
                ;;
            "low")
                echo -e "${GREEN}$alert_date $alert_time [LOW] $alert_msg${NC}"
                ;;
        esac
    done < <(tail -50 "$ALERT_FILE")
}

# start real-time monitoring
start_monitor() {
    echo -e "${GREEN}starting real-time threat monitoring...${NC}"
    echo -e "${CYAN}press Ctrl+C to stop${NC}"
    echo ""
    
    while true; do
        clear
        echo -e "${MAGENTA}=== milanY threat intelligence monitor ===${NC}"
        echo -e "${WHITE}last updated: $(date)${NC}"
        echo ""
        
        # show system status
        echo -e "${CYAN}[ system status ]${NC}"
        echo -e "${WHITE}threat database size: $(du -sh "$THREAT_FEED_DIR" 2>/dev/null | cut -f1)${NC}"
        echo -e "${WHITE}recent alerts: $(grep -c "$(date '+%Y-%m-%d')" "$ALERT_FILE" 2>/dev/null || echo 0)${NC}"
        echo ""
        
        # show top threats
        echo -e "${CYAN}[ top recent threats ]${NC}"
        show_alerts 1 high
        
        echo ""
        echo -e "${CYAN}next update in 30 seconds...${NC}"
        
        sleep 30
    done
}

# search threat database
search_threats() {
    local term="$1"
    
    if [ -z "$term" ]; then
        echo -e "${RED}error: search term required${NC}"
        return 1
    fi
    
    echo -e "${BLUE}searching threat database for: $term${NC}"
    echo ""
    
    # search cve database
    if [ -f "$THREAT_FEED_DIR/cve_recent.json" ]; then
        echo -e "${CYAN}[ cve matches ]${NC}"
        jq -r --arg term "$term" '.[] | select(.id | test($term; "i")) | "\(.id) - \(.summary)"' "$THREAT_FEED_DIR/cve_recent.json" 2>/dev/null | head -5
        echo ""
    fi
    
    # search malware signatures
    if [ -f "$THREAT_FEED_DIR/malware.yar" ]; then
        echo -e "${CYAN}[ malware signature matches ]${NC}"
        grep -i "$term" "$THREAT_FEED_DIR/malware.yar" | head -5
        echo ""
    fi
    
    # search phishing domains
    if [ -f "$THREAT_FEED_DIR/phishing_domains.txt" ]; then
        echo -e "${CYAN}[ phishing domain matches ]${NC}"
        grep -i "$term" "$THREAT_FEED_DIR/phishing_domains.txt" | head -5
    fi
}

# generate threat report
generate_report() {
    local report_file="/tmp/milany-threat-report-$(date +%Y%m%d-%H%M%S).txt"
    
    echo -e "${CYAN}generating threat intelligence report...${NC}"
    
    cat > "$report_file" << EOF
milanY threat intelligence report
generated: $(date)
=====================================

threat database status:
- cve entries: $(jq length "$THREAT_FEED_DIR/cve_recent.json" 2>/dev/null || echo 0)
- malware signatures: $(wc -l < "$THREAT_FEED_DIR/malware.yar" 2>/dev/null || echo 0)
- phishing domains: $(wc -l < "$THREAT_FEED_DIR/phishing_domains.txt" 2>/dev/null || echo 0)
- malicious ips: $(wc -l < "$THREAT_FEED_DIR/malicious_ips.txt" 2>/dev/null || echo 0)

recent alerts:
$(show_alerts 7)

recommendations:
• keep threat database updated daily
• scan all new connections
• monitor system logs for suspicious activity
• use vpn when accessing untrusted networks
• enable automatic threat alerts

EOF
    
    echo -e "${GREEN}report saved to: $report_file${NC}"
}

# show threat statistics
show_stats() {
    echo -e "${CYAN}[ threat intelligence statistics ]${NC}"
    echo ""
    
    echo -e "${WHITE}database statistics:${NC}"
    echo "  cve entries: $(jq length "$THREAT_FEED_DIR/cve_recent.json" 2>/dev/null || echo 0)"
    echo "  malware signatures: $(wc -l < "$THREAT_FEED_DIR/malware.yar" 2>/dev/null || echo 0)"
    echo "  phishing domains: $(wc -l < "$THREAT_FEED_DIR/phishing_domains.txt" 2>/dev/null || echo 0)"
    echo "  malicious ips: $(wc -l < "$THREAT_FEED_DIR/malicious_ips.txt" 2>/dev/null || echo 0)"
    echo ""
    
    echo -e "${WHITE}alert statistics:${NC}"
    echo "  total alerts: $(wc -l < "$ALERT_FILE" 2>/dev/null || echo 0)"
    echo "  alerts today: $(grep -c "$(date '+%Y-%m-%d')" "$ALERT_FILE" 2>/dev/null || echo 0)"
    echo "  critical alerts: $(grep -c "critical" "$ALERT_FILE" 2>/dev/null || echo 0)"
    echo ""
    
    echo -e "${WHITE}last update: $(stat -c %Y "$THREAT_FEED_DIR" 2>/dev/null || echo "never")${NC}"
}

# log alert
log_alert() {
    local level="$1"
    local message="$2"
    local timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    
    echo "$timestamp milany-threat-intel [$level] $message" >> "$ALERT_FILE"
    
    # show immediate alert for critical issues
    if [ "$level" = "critical" ]; then
        echo -e "${RED}CRITICAL ALERT: $message${NC}"
    fi
}

# main function
main() {
    init_directories
    
    case "${1:-help}" in
        update)
            update_feeds
            ;;
        scan)
            scan_target "$2"
            ;;
        alerts)
            show_alerts "$2" "$3"
            ;;
        monitor)
            start_monitor
            ;;
        report)
            generate_report
            ;;
        search)
            search_threats "$2"
            ;;
        stats)
            show_stats
            ;;
        -h|--help)
            show_help
            ;;
        *)
            echo -e "${RED}error: unknown command${NC}"
            show_help
            exit 1
            ;;
    esac
}

# handle signals
trap 'echo -e "\n${YELLOW}monitoring stopped${NC}"; exit 0' SIGINT SIGTERM

# run main function
main "$@"
