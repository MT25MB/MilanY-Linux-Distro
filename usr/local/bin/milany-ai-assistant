#!/bin/bash
# milanY ai assistant
# integrates gemini ai for intelligent features

CONFIG_FILE="/etc/milany/milany.conf"
CACHE_DIR="/tmp/milany-ai"

# colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m'

# load configuration
if [ -f "$CONFIG_FILE" ]; then
    source "$CONFIG_FILE"
else
    echo -e "${RED}error: config file not found${NC}"
    exit 1
fi

# check if gemini key is configured
if [ -z "$GEMINI_API_KEY" ]; then
    echo -e "${RED}error: gemini api key not configured${NC}"
    echo "configure it in /etc/milany/milany.conf"
    exit 1
fi

# create cache directory
mkdir -p "$CACHE_DIR"

# make ai request
ask_gemini() {
    local prompt="$1"
    local context="$2"
    
    # build request
    local request=$(jq -n \
        --arg contents "$(printf '[{"parts":[{"text":"%s"}]},{"parts":[{"text":"%s"}]}' "$context" "$prompt")" \
        '{"contents": $contents}')
    
    # make api call
    local response=$(curl -s \
        -H "Content-Type: application/json" \
        -H "x-goog-api-key: $GEMINI_API_KEY" \
        -d "$request" \
        "https://generativelanguage.googleapis.com/v1beta/models/gemini-pro:generateContent")
    
    # extract response
    echo "$response" | jq -r '.candidates[0].content.parts[0].text // "error: no response"'
}

# system analysis
analyze_system() {
    echo -e "${CYAN}analyzing system...${NC}"
    
    local context="you are a cybersecurity expert helping with system analysis on a privacy-focused linux distro called milanY"
    local prompt="analyze this system output and provide security recommendations:
    
    $(uname -a)
    $(df -h)
    $(free -h)
    $(ps aux | head -20)
    $(netstat -tuln 2>/dev/null || ss -tuln)
    
    focus on privacy, security, and performance optimizations"
    
    ask_gemini "$prompt" "$context"
}

# privacy advisor
privacy_advisor() {
    local topic="$1"
    
    echo -e "${CYAN}privacy advisor: $topic${NC}"
    
    local context="you are a privacy and security expert specializing in digital anonymity, encryption, and secure communications"
    local prompt="provide detailed advice about: $topic
    
    include practical steps, tools, and best practices for maintaining privacy and anonymity online"
    
    ask_gemini "$prompt" "$context"
}

# threat intelligence
threat_intel() {
    local query="$1"
    
    echo -e "${CYAN}threat intelligence: $query${NC}"
    
    local context="you are a cybersecurity threat intelligence analyst"
    local prompt="analyze this threat or vulnerability: $query
    
    provide risk assessment, mitigation strategies, and recommended defensive measures"
    
    ask_gemini "$prompt" "$context"
}

# crypto helper
crypto_helper() {
    local action="$1"
    local data="$2"
    
    case "$action" in
        "generate")
            echo -e "${CYAN}generating encryption recommendations...${NC}"
            local context="you are a cryptography expert"
            local prompt="recommend the best encryption methods and tools for: $data
            
            include specific commands, key sizes, and security considerations"
            ask_gemini "$prompt" "$context"
            ;;
        "analyze")
            echo -e "${CYAN}analyzing cryptographic setup...${NC}"
            local context="you are a cryptography auditor"
            local prompt="analyze this cryptographic configuration for security: $data
            
            identify potential vulnerabilities and suggest improvements"
            ask_gemini "$prompt" "$context"
            ;;
    esac
}

# interactive mode
interactive_mode() {
    echo -e "${GREEN}milanY AI Assistant - Interactive Mode${NC}"
    echo -e "${YELLOW}type 'help' for commands or 'quit' to exit${NC}"
    echo ""
    
    while true; do
        echo -n -e "${CYAN}milany>${NC} "
        read -r input
        
        case "$input" in
            "quit"|"exit")
                echo -e "${YELLOW}goodbye${NC}"
                break
                ;;
            "help")
                echo -e "${GREEN}available commands:${NC}"
                echo "  analyze - analyze system security"
                echo "  privacy <topic> - get privacy advice"
                echo "  threat <query> - threat intelligence"
                echo "  crypto generate <data> - encryption recommendations"
                echo "  crypto analyze <data> - analyze crypto setup"
                echo "  quit - exit assistant"
                ;;
            analyze*)
                analyze_system
                ;;
            privacy*)
                local topic=$(echo "$input" | sed 's/privacy //')
                privacy_advisor "$topic"
                ;;
            threat*)
                local query=$(echo "$input" | sed 's/threat //')
                threat_intel "$query"
                ;;
            crypto*)
                local action=$(echo "$input" | awk '{print $2}')
                local data=$(echo "$input" | cut -d' ' -f3-)
                crypto_helper "$action" "$data"
                ;;
            *)
                # direct chat with gemini
                local context="you are a helpful AI assistant for milanY linux, a privacy-focused distro. be helpful, concise, and security-conscious."
                ask_gemini "$input" "$context"
                ;;
        esac
        
        echo ""
    done
}

# main function
main() {
    case "${1:-interactive}" in
        "analyze")
            analyze_system
            ;;
        "privacy")
            privacy_advisor "$2"
            ;;
        "threat")
            threat_intel "$2"
            ;;
        "crypto")
            crypto_helper "$2" "$3"
            ;;
        "interactive")
            interactive_mode
            ;;
        *)
            echo "usage: $0 [analyze|privacy <topic>|threat <query>|crypto <action> <data>|interactive]"
            exit 1
            ;;
    esac
}

# run main function
main "$@"
