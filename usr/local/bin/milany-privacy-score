#!/bin/bash
# milanY privacy score monitoring system
# real-time privacy and security assessment

# colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
MAGENTA='\033[0;35m'
WHITE='\033[1;37m'
NC='\033[0m'

# score categories
NETWORK_SCORE=0
SYSTEM_SCORE=0
APPLICATION_SCORE=0
ENCRYPTION_SCORE=0
OVERALL_SCORE=0

# help function
show_help() {
    echo -e "${CYAN}milany-privacy-score - privacy monitoring system${NC}"
    echo ""
    echo "usage: milany-privacy-score [command]"
    echo ""
    echo "commands:"
    echo "  check              run privacy assessment"
    echo "  monitor            start real-time monitoring"
    echo "  report             generate detailed report"
    echo "  history            show score history"
    echo "  benchmark          compare with privacy standards"
    echo "  improve            show improvement suggestions"
    echo ""
    echo "examples:"
    echo "  milany-privacy-score check"
    echo "  milany-privacy-score monitor"
    echo "  milany-privacy-score report"
}

# calculate network privacy score
calculate_network_score() {
    local score=100
    
    # check tor status
    if systemctl is-active --quiet tor; then
        echo -e "${GREEN}✓ tor service active (+20)${NC}"
        score=$((score + 20))
    else
        echo -e "${RED}✗ tor service inactive (-20)${NC}"
        score=$((score - 20))
    fi
    
    # check dnscrypt
    if systemctl is-active --quiet dnscrypt-proxy; then
        echo -e "${GREEN}✓ encrypted dns active (+15)${NC}"
        score=$((score + 15))
    else
        echo -e "${RED}✗ encrypted dns inactive (-15)${NC}"
        score=$((score - 15))
    fi
    
    # check firewall
    if systemctl is-active --quiet iptables; then
        echo -e "${GREEN}✓ firewall active (+15)${NC}"
        score=$((score + 15))
    else
        echo -e "${RED}✗ firewall inactive (-15)${NC}"
        score=$((score - 15))
    fi
    
    # check for open ports
    local open_ports=$(ss -tuln | grep LISTEN | wc -l)
    if [ "$open_ports" -lt 10 ]; then
        echo -e "${GREEN}✓ minimal open ports (+10)${NC}"
        score=$((score + 10))
    else
        echo -e "${YELLOW}⚠ many open ports (-5)${NC}"
        score=$((score - 5))
    fi
    
    # check vpn status
    if ip link show | grep -q "tun"; then
        echo -e "${GREEN}✓ vpn tunnel active (+10)${NC}"
        score=$((score + 10))
    fi
    
    # cap score at 0-100
    if [ $score -gt 100 ]; then
        score=100
    elif [ $score -lt 0 ]; then
        score=0
    fi
    
    NETWORK_SCORE=$score
}

# calculate system privacy score
calculate_system_score() {
    local score=100
    
    # check apparmor
    if systemctl is-active --quiet apparmor; then
        echo -e "${GREEN}✓ apparmor active (+15)${NC}"
        score=$((score + 15))
    else
        echo -e "${RED}✗ apparmor inactive (-15)${NC}"
        score=$((score - 15))
    fi
    
    # check secure boot
    if [ -d /sys/firmware/efi ]; then
        local secure_boot=$(od -An -t u1 /sys/firmware/efi/vars/SecureBoot-*/data 2>/dev/null | tr -d ' ')
        if [ "$secure_boot" = "1" ]; then
            echo -e "${GREEN}✓ secure boot enabled (+10)${NC}"
            score=$((score + 10))
        fi
    fi
    
    # check kernel hardening
    if grep -q "kernel.dmesg_restrict = 1" /etc/sysctl.d/99-milany-security.conf 2>/dev/null; then
        echo -e "${GREEN}✓ kernel hardening active (+10)${NC}"
        score=$((score + 10))
    else
        echo -e "${RED}✗ kernel hardening missing (-10)${NC}"
        score=$((score - 10))
    fi
    
    # check file permissions
    local home_perms=$(stat -c %a ~)
    if [ "$home_perms" = "700" ]; then
        echo -e "${GREEN}✓ secure home directory (+5)${NC}"
        score=$((score + 5))
    else
        echo -e "${YELLOW}⚠ insecure home permissions (-5)${NC}"
        score=$((score - 5))
    fi
    
    # check for tracking services
    if ! systemctl is-enabled --quiet bluetooth 2>/dev/null; then
        echo -e "${GREEN}✓ bluetooth disabled (+5)${NC}"
        score=$((score + 5))
    fi
    
    if ! systemctl is-enabled --quiet cups 2>/dev/null; then
        echo -e "${GREEN}✓ printing disabled (+5)${NC}"
        score=$((score + 5))
    fi
    
    # cap score
    if [ $score -gt 100 ]; then
        score=100
    elif [ $score -lt 0 ]; then
        score=0
    fi
    
    SYSTEM_SCORE=$score
}

# calculate application privacy score
calculate_application_score() {
    local score=100
    
    # check browser privacy
    if [ -f ~/.mozilla/firefox/default/user.js ]; then
        if grep -q "privacy.resistFingerprinting = true" ~/.mozilla/firefox/default/user.js; then
            echo -e "${GREEN}✓ firefox fingerprinting protection (+15)${NC}"
            score=$((score + 15))
        fi
        
        if grep -q "network.cookie.cookieBehavior = 1" ~/.mozilla/firefox/default/user.js; then
            echo -e "${GREEN}✓ firefox cookie protection (+10)${NC}"
            score=$((score + 10))
        fi
    fi
    
    # check for telemetry
    if ! systemctl is-enabled --quiet systemd-journal-upload 2>/dev/null; then
        echo -e "${GREEN}✓ telemetry disabled (+10)${NC}"
        score=$((score + 10))
    fi
    
    # check for location services
    if ! systemctl is-enabled --quiet geoclue 2>/dev/null; then
        echo -e "${GREEN}✓ location services disabled (+10)${NC}"
        score=$((score + 10))
    fi
    
    # check for insecure apps
    if systemctl is-enabled --quiet avahi-daemon 2>/dev/null; then
        echo -e "${RED}✗ zeroconf enabled (-10)${NC}"
        score=$((score - 10))
    fi
    
    # cap score
    if [ $score -gt 100 ]; then
        score=100
    elif [ $score -lt 0 ]; then
        score=0
    fi
    
    APPLICATION_SCORE=$score
}

# calculate encryption score
calculate_encryption_score() {
    local score=100
    
    # check full disk encryption
    if lsblk -o TYPE,MOUNTPOINT | grep -q "crypt.* /"; then
        echo -e "${GREEN}✓ full disk encryption active (+25)${NC}"
        score=$((score + 25))
    else
        echo -e "${RED}✗ no full disk encryption (-25)${NC}"
        score=$((score - 25))
    fi
    
    # check swap encryption
    if grep -q "swap" /etc/crypttab 2>/dev/null; then
        echo -e "${GREEN}✓ encrypted swap (+15)${NC}"
        score=$((score + 15))
    fi
    
    # check home encryption
    if [ -d ~/Private ] && mount | grep -q "ecryptfs"; then
        echo -e "${GREEN}✓ home directory encrypted (+15)${NC}"
        score=$((score + 15))
    fi
    
    # check for gpg keys
    if gpg --list-secret-keys 2>/dev/null | grep -q "sec"; then
        echo -e "${GREEN}✓ gpg keys present (+10)${NC}"
        score=$((score + 10))
    fi
    
    # check for ssh hardening
    if [ -f /etc/ssh/sshd_config ]; then
        if grep -q "^PasswordAuthentication no" /etc/ssh/sshd_config; then
            echo -e "${GREEN}✓ ssh password auth disabled (+10)${NC}"
            score=$((score + 10))
        fi
    fi
    
    # cap score
    if [ $score -gt 100 ]; then
        score=100
    elif [ $score -lt 0 ]; then
        score=0
    fi
    
    ENCRYPTION_SCORE=$score
}

# calculate overall score
calculate_overall_score() {
    OVERALL_SCORE=$(( (NETWORK_SCORE + SYSTEM_SCORE + APPLICATION_SCORE + ENCRYPTION_SCORE) / 4 ))
}

# display score with color
display_score() {
    local score=$1
    local label=$2
    
    if [ $score -ge 80 ]; then
        echo -e "${GREEN}$label: $score/100 ✓${NC}"
    elif [ $score -ge 60 ]; then
        echo -e "${YELLOW}$label: $score/100 ⚠${NC}"
    else
        echo -e "${RED}$label: $score/100 ✗${NC}"
    fi
}

# save score to history
save_score() {
    local timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    local score_file="/var/log/milany-privacy-scores.log"
    
    # create score file if not exists
    sudo mkdir -p "$(dirname "$score_file")"
    sudo touch "$score_file"
    sudo chmod 666 "$score_file"
    
    # save score
    echo "$timestamp,$OVERALL_SCORE,$NETWORK_SCORE,$SYSTEM_SCORE,$APPLICATION_SCORE,$ENCRYPTION_SCORE" >> "$score_file"
}

# run privacy check
run_check() {
    echo -e "${MAGENTA}=== milanY privacy assessment ===${NC}"
    echo ""
    
    echo -e "${CYAN}[ network privacy ]${NC}"
    calculate_network_score
    display_score $NETWORK_SCORE "network score"
    echo ""
    
    echo -e "${CYAN}[ system privacy ]${NC}"
    calculate_system_score
    display_score $SYSTEM_SCORE "system score"
    echo ""
    
    echo -e "${CYAN}[ application privacy ]${NC}"
    calculate_application_score
    display_score $APPLICATION_SCORE "application score"
    echo ""
    
    echo -e "${CYAN}[ encryption privacy ]${NC}"
    calculate_encryption_score
    display_score $ENCRYPTION_SCORE "encryption score"
    echo ""
    
    calculate_overall_score
    
    echo -e "${MAGENTA}=== overall privacy score ===${NC}"
    display_score $OVERALL_SCORE "overall score"
    echo ""
    
    # save score
    save_score
    
    # provide recommendations
    if [ $OVERALL_SCORE -lt 80 ]; then
        echo -e "${YELLOW}recommendations: run 'milany-privacy-score improve'${NC}"
    fi
}

# start real-time monitoring
start_monitor() {
    echo -e "${GREEN}starting real-time privacy monitoring...${NC}"
    echo -e "${CYAN}press Ctrl+C to stop${NC}"
    echo ""
    
    while true; do
        clear
        echo -e "${MAGENTA}=== milanY privacy monitor ===${NC}"
        echo -e "${WHITE}last updated: $(date)${NC}"
        echo ""
        
        calculate_network_score
        calculate_system_score
        calculate_application_score
        calculate_encryption_score
        calculate_overall_score
        
        echo -e "${CYAN}[ scores ]${NC}"
        display_score $NETWORK_SCORE "network"
        display_score $SYSTEM_SCORE "system"
        display_score $APPLICATION_SCORE "application"
        display_score $ENCRYPTION_SCORE "encryption"
        echo ""
        display_score $OVERALL_SCORE "overall"
        
        sleep 30
    done
}

# generate detailed report
generate_report() {
    local report_file="/tmp/milany-privacy-report-$(date +%Y%m%d-%H%M%S).txt"
    
    echo -e "${CYAN}generating privacy report...${NC}"
    
    cat > "$report_file" << EOF
milanY privacy assessment report
generated: $(date)
=====================================

network privacy score: $NETWORK_SCORE/100
system privacy score: $SYSTEM_SCORE/100
application privacy score: $APPLICATION_SCORE/100
encryption privacy score: $ENCRYPTION_SCORE/100
overall privacy score: $OVERALL_SCORE/100

detailed analysis:
$(run_check)

recommendations:
$(milany-privacy-score improve)
EOF
    
    echo -e "${GREEN}report saved to: $report_file${NC}"
}

# show score history
show_history() {
    local score_file="/var/log/milany-privacy-scores.log"
    
    if [ ! -f "$score_file" ]; then
        echo -e "${YELLOW}no score history found${NC}"
        return
    fi
    
    echo -e "${CYAN}[ privacy score history ]${NC}"
    echo "date                overall  network  system   app      encrypt"
    echo "----                -------  -------  ------   ---      -------"
    
    tail -20 "$score_file" | while IFS=',' read -r timestamp overall network system app encrypt; do
        printf "%-20s %-8s %-8s %-8s %-8s %-8s\n" "$timestamp" "$overall" "$network" "$system" "$app" "$encrypt"
    done
}

# show improvement suggestions
show_improvements() {
    echo -e "${CYAN}[ privacy improvement suggestions ]${NC}"
    echo ""
    
    if [ $NETWORK_SCORE -lt 80 ]; then
        echo -e "${YELLOW}network improvements:${NC}"
        echo "  • enable tor service"
        echo "  • configure dnscrypt-proxy"
        echo "  • setup firewall rules"
        echo "  • use vpn for additional anonymity"
        echo ""
    fi
    
    if [ $SYSTEM_SCORE -lt 80 ]; then
        echo -e "${YELLOW}system improvements:${NC}"
        echo "  • enable apparmor profiles"
        echo "  • enable secure boot"
        echo "  • configure kernel hardening"
        echo "  • secure home directory permissions"
        echo ""
    fi
    
    if [ $APPLICATION_SCORE -lt 80 ]; then
        echo -e "${YELLOW}application improvements:${NC}"
        echo "  • configure firefox privacy settings"
        echo "  • disable telemetry services"
        echo "  • turn off location services"
        echo "  • remove zeroconf services"
        echo ""
    fi
    
    if [ $ENCRYPTION_SCORE -lt 80 ]; then
        echo -e "${YELLOW}encryption improvements:${NC}"
        echo "  • setup full disk encryption"
        echo "  • enable encrypted swap"
        echo "  • create gpg encryption keys"
        echo "  • harden ssh configuration"
        echo ""
    fi
}

# benchmark against standards
benchmark() {
    echo -e "${CYAN}[ privacy benchmark comparison ]${NC}"
    echo ""
    
    echo -e "${WHITE}your score: $OVERALL_SCORE/100${NC}"
    echo ""
    
    echo -e "${CYAN}privacy standards:${NC}"
    echo "  • excellent: 90-100"
    echo "  • good: 70-89"
    echo "  • fair: 50-69"
    echo "  • poor: 0-49"
    echo ""
    
    if [ $OVERALL_SCORE -ge 90 ]; then
        echo -e "${GREEN}your privacy level: excellent${NC}"
        echo "you have maximum privacy protection"
    elif [ $OVERALL_SCORE -ge 70 ]; then
        echo -e "${YELLOW}your privacy level: good${NC}"
        echo "you have strong privacy protection"
    elif [ $OVERALL_SCORE -ge 50 ]; then
        echo -e "${YELLOW}your privacy level: fair${NC}"
        echo "consider improving your privacy settings"
    else
        echo -e "${RED}your privacy level: poor${NC}"
        echo "privacy improvements are strongly recommended"
    fi
}

# main function
main() {
    case "${1:-check}" in
        check)
            run_check
            ;;
        monitor)
            start_monitor
            ;;
        report)
            generate_report
            ;;
        history)
            show_history
            ;;
        benchmark)
            run_check
            benchmark
            ;;
        improve)
            show_improvements
            ;;
        -h|--help)
            show_help
            ;;
        *)
            echo -e "${RED}error: unknown command${NC}"
            show_help
            exit 1
            ;;
    esac
}

# handle signals
trap 'echo -e "\n${YELLOW}monitoring stopped${NC}"; exit 0' SIGINT SIGTERM

# run main function
main "$@"
