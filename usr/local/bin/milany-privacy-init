#!/bin/bash
# milanY privacy initialization
# hardens system for maximum privacy and security

CONFIG_FILE="/etc/milany/milany.conf"

# colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m'

# load configuration
if [ -f "$CONFIG_FILE" ]; then
    source "$CONFIG_FILE"
else
    echo -e "${RED}error: config file not found${NC}"
    exit 1
fi

# check if running as root
if [[ $EUID -ne 0 ]]; then
   echo -e "${RED}error: this script must be run as root${NC}"
   exit 1
fi

echo -e "${CYAN}initializing milanY privacy protections...${NC}"

# kernel hardening
setup_kernel_hardening() {
    echo -e "${BLUE}configuring kernel hardening...${NC}"
    
    # create sysctl.d directory
    mkdir -p /etc/sysctl.d
    
    # kernel hardening configuration
    cat > /etc/sysctl.d/99-milany-security.conf << 'EOF'
# milanY kernel hardening
# privacy and security focused

# network security
net.ipv4.ip_forward = 0
net.ipv6.conf.all.forwarding = 0
net.ipv4.conf.all.send_redirects = 0
net.ipv4.conf.default.send_redirects = 0
net.ipv4.conf.all.accept_source_route = 0
net.ipv4.conf.default.accept_source_route = 0
net.ipv6.conf.all.accept_source_route = 0
net.ipv6.conf.default.accept_source_route = 0
net.ipv4.conf.all.accept_redirects = 0
net.ipv4.conf.default.accept_redirects = 0
net.ipv6.conf.all.accept_redirects = 0
net.ipv6.conf.default.accept_redirects = 0
net.ipv4.conf.all.secure_redirects = 0
net.ipv4.conf.default.secure_redirects = 0
net.ipv4.conf.all.log_martians = 1
net.ipv4.conf.default.log_martians = 1

# tcp hardening
net.ipv4.tcp_syncookies = 1
net.ipv4.tcp_rfc1337 = 1
net.ipv4.tcp_timestamps = 0
net.ipv4.tcp_sack = 0

# memory protection
kernel.dmesg_restrict = 1
kernel.kptr_restrict = 2
kernel.perf_event_paranoid = 3
kernel.kexec_load_disabled = 1
kernel.unprivileged_bpf_disabled = 1

# file system protection
fs.protected_regular = 2
fs.protected_fifos = 2
fs.suid_dumpable = 0

# exec shield
kernel.exec-shield = 2
kernel.randomize_va_space = 2

# restrict core dumps
fs.suid_dumpable = 0
kernel.core_pattern = |/bin/false

# disable magic sysrq
kernel.sysrq = 0

# restrict ptrace
kernel.yama.ptrace_scope = 3
EOF

    # apply sysctl settings
    sysctl -p /etc/sysctl.d/99-milany-security.conf
}

# firewall setup
setup_firewall() {
    echo -e "${BLUE}configuring firewall...${NC}"
    
    # create iptables rules
    cat > /etc/iptables/iptables.rules << 'EOF'
# milanY firewall rules
# deny by default, allow by exception

*filter
:INPUT DROP [0:0]
:FORWARD DROP [0:0]
:OUTPUT DROP [0:0]

# allow loopback
-A INPUT -i lo -j ACCEPT
-A OUTPUT -o lo -j ACCEPT

# allow established connections
-A INPUT -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT
-A OUTPUT -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT

# allow dns
-A OUTPUT -p udp --dport 53 -j ACCEPT
-A OUTPUT -p tcp --dport 53 -j ACCEPT

# allow dhcp
-A OUTPUT -p udp --dport 67:68 -j ACCEPT

# allow outbound http/https (can be restricted further)
-A OUTPUT -p tcp --dport 80 -j ACCEPT
-A OUTPUT -p tcp --dport 443 -j ACCEPT

# allow tor if enabled
-A OUTPUT -m owner --uid-owner tor -j ACCEPT
-A OUTPUT -p tcp --dport 9050 -j ACCEPT
-A OUTPUT -p tcp --dport 9051 -j ACCEPT

# allow ssh (customize as needed)
# -A INPUT -p tcp --dport 22 -j ACCEPT

# icmp
-A INPUT -p icmp --icmp-type echo-request -m limit --limit 1/s -j ACCEPT
-A OUTPUT -p icmp --icmp-type echo-request -j ACCEPT

COMMIT
EOF

    # apply firewall rules
    iptables-restore < /etc/iptables/iptables.rules
    
    # enable iptables service
    systemctl enable iptables
    systemctl start iptables
}

# tor configuration
setup_tor() {
    if [ "$ENABLE_TOR" = true ]; then
        echo -e "${BLUE}configuring tor...${NC}"
        
        # create tor config
        cat > /etc/tor/torrc << 'EOF'
# milanY tor configuration
# privacy focused

DataDirectory /var/lib/tor
PidFile /run/tor/tor.pid

RunAsDaemon 1
ControlPort 9051
CookieAuthentication 1
CookieAuthFileGroupReadable 1

# exit node restrictions (adjust as needed)
ExitNodes {us}
StrictNodes 1

# circuit building
MaxCircuitDirtiness 600
NewCircuitPeriod 60

# privacy settings
AvoidDiskWrites 1
SafeLogging 1
Log notice file /var/log/tor/notices.log
Log err file /var/log/tor/error.log

# dns
DNSPort 5353
AutomapHostsOnResolve 1
AutomapHostsSuffixes .exit,.onion

# transproxy
TransPort 9040
TransListenAddress 127.0.0.1
EOF
        
        # enable tor service
        systemctl enable tor
        systemctl start tor
        
        echo -e "${GREEN}tor service started${NC}"
    fi
}

# dnscrypt configuration
setup_dnscrypt() {
    if [ "$ENABLE_DNSCRYPT" = true ]; then
        echo -e "${BLUE}configuring dnscrypt-proxy...${NC}"
        
        # create dnscrypt config
        cat > /etc/dnscrypt-proxy/dnscrypt-proxy.toml << 'EOF'
# milanY dnscrypt-proxy configuration
# encrypted dns for privacy

server_names = ['cloudflare', 'google']
listen_addresses = ['127.0.0.1:5300']
max_clients = 250
ipv4_servers = true
ipv6_servers = false
dnscrypt_servers = true
doh_servers = true
require_dnssec = true
require_nolog = true
require_nofilter = true

# fallback to safe servers if needed
fallback_resolvers = ['9.9.9.9:53', '1.1.1.1:53']

# cache configuration
cache = true
cache_size = 512
cache_ttl_min = 60
cache_ttl_max = 86400

# logging
log_level = 2
log_file = '/var/log/dnscrypt-proxy/dnscrypt-proxy.log'

# blocked addresses
blocked_names = ['ads.example.com']
blocked_ips = ['192.168.0.0/16']
EOF
        
        # configure systemd-resolved to use dnscrypt
        mkdir -p /etc/systemd/resolved.conf.d
        cat > /etc/systemd/resolved.conf.d/dnscrypt.conf << 'EOF'
[Resolve]
DNS=127.0.0.1:5300
FallbackDNS=9.9.9.9 1.1.1.1
DNSSEC=yes
DNSOverTLS=no
Cache=no
EOF
        
        # restart systemd-resolved
        systemctl restart systemd-resolved
        
        # enable dnscrypt-proxy
        systemctl enable dnscrypt-proxy
        systemctl start dnscrypt-proxy
        
        echo -e "${GREEN}dnscrypt-proxy service started${NC}"
    fi
}

# apparmor hardening
setup_apparmor() {
    if [ "$ENABLE_APPARMOR" = true ]; then
        echo -e "${BLUE}configuring apparmor...${NC}"
        
        # enable apparmor
        systemctl enable apparmor
        systemctl start apparmor
        
        # put all profiles in enforce mode
        aa-enforce /etc/apparmor.d/* 2>/dev/null || true
        
        echo -e "${GREEN}apparmor hardening enabled${NC}"
    fi
}

# secure temporary directories
setup_tmp_security() {
    echo -e "${BLUE}securing temporary directories...${NC}"
    
    # add tmpfs entries to fstab
    if ! grep -q "tmpfs /tmp" /etc/fstab; then
        echo "tmpfs /tmp tmpfs defaults,noexec,nosuid,size=1G 0 0" >> /etc/fstab
    fi
    
    if ! grep -q "tmpfs /var/tmp" /etc/fstab; then
        echo "tmpfs /var/tmp tmpfs defaults,noexec,nosuid,size=500M 0 0" >> /etc/fstab
    fi
    
    # mount tmpfs
    mount -a
}

# disable unnecessary services
disable_services() {
    echo -e "${BLUE}disabling unnecessary services...${NC}"
    
    # list of services to disable for privacy
    services=(
        "bluetooth"
        "cups"
        "avahi-daemon"
        "pulseaudio"
        "geoclue"
        "whoopsie"
        " apport"
        "kerneloops"
        "systemd-journal-upload"
        "systemd-networkd-wait-online"
    )
    
    for service in "${services[@]}"; do
        systemctl disable "$service" 2>/dev/null || true
        systemctl stop "$service" 2>/dev/null || true
    done
}

# setup user privacy
setup_user_privacy() {
    echo -e "${BLUE}configuring user privacy...${NC}"
    
    # create privacy script for users
    cat > /usr/local/bin/milany-user-privacy << 'EOF'
#!/bin/bash
# milanY user privacy setup

# disable bash history
unset HISTFILE
export HISTSIZE=0
export HISTFILESIZE=0

# disable core dumps
ulimit -c 0

# secure umask
umask 077

# disable shell tracking
export LESSHISTFILE=-
export W3M_DIR=/dev/null

# firefox privacy settings
mkdir -p ~/.mozilla/firefox/default
cat > ~/.mozilla/firefox/default/user.js << 'FF'
// milanY firefox privacy settings
user_pref("privacy.donottrackheader.enabled", true);
user_pref("privacy.trackingprotection.enabled", true);
user_pref("privacy.trackingprotection.pbmode.enabled", true);
user_pref("browser.send_pings", false);
user_pref("beacon.enabled", false);
user_pref("dom.battery.enabled", false);
user_pref("device.sensors.enabled", false);
user_pref("camera.autoplay.enabled", false);
user_pref("media.autoplay.default", 5);
user_pref("media.peerconnection.enabled", false);
user_pref("network.cookie.cookieBehavior", 1);
user_pref("network.http.referer.spoofSource", true);
user_pref("privacy.firstparty.isolate", true);
user_pref("privacy.resistFingerprinting", true);
FF

echo "user privacy settings applied"
EOF
    
    chmod +x /usr/local/bin/milany-user-privacy
}

# main execution
main() {
    echo -e "${GREEN}starting milanY privacy hardening...${NC}"
    
    setup_kernel_hardening
    setup_firewall
    setup_tor
    setup_dnscrypt
    setup_apparmor
    setup_tmp_security
    disable_services
    setup_user_privacy
    
    echo -e "${GREEN}milanY privacy hardening complete${NC}"
    echo -e "${CYAN}system is now optimized for privacy and security${NC}"
}

# run main function
main "$@"
