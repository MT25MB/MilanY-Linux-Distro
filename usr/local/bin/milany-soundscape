#!/bin/bash
# milanY system soundscape
# ambient sound system for milanY

# colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
MAGENTA='\033[0;35m'
WHITE='\033[1;37m'
NC='\033[0m'

# soundscape configuration
SOUNDSCAPE_DIR="/var/lib/milany-soundscape"
SOUNDSCAPE_CONFIG="$SOUNDSCAPE_DIR/config.json"
SOUNDSCAPE_CACHE="$SOUNDSCAPE_DIR/cache"

# help function
show_help() {
    echo -e "${CYAN}milany-soundscape - system ambient sounds${NC}"
    echo ""
    echo "usage: milany-soundscape [command] [options]"
    echo ""
    echo "commands:"
    echo "  start                  start soundscape"
    echo "  stop                   stop soundscape"
    echo "  restart                restart soundscape"
    echo "  theme <name>           set soundscape theme"
    echo "  themes                 list available themes"
    echo "  volume <level>         set volume level"
    echo "  events                 enable event sounds"
    echo "  create <name>          create custom theme"
    echo "  mix <theme1> <theme2> mix themes"
    echo ""
    echo "soundscape themes:"
    echo "  cyberpunk              futuristic ambient sounds"
    echo "  matrix                matrix-like digital ambiance"
    echo "  nature                calming natural sounds"
    echo "  space                 space station ambiance"
    echo "  datacenter            server room sounds"
    echo "  retro                 retro computer sounds"
    echo "  minimal               minimal electronic sounds"
    echo "  rain                  rain ambiance"
    echo ""
    echo "event sounds:"
    echo "  notifications          system notifications"
    echo "  alerts                security alerts"
    echo "  transitions           theme transitions"
    echo "  interactions          user interactions"
    echo ""
    echo "examples:"
    echo "  milany-soundscape start"
    echo "  milany-soundscape theme cyberpunk"
    echo "  milany-soundscape volume 50"
}

# initialize soundscape system
init_soundscape() {
    mkdir -p "$SOUNDSCAPE_DIR"
    mkdir -p "$SOUNDSCAPE_CACHE"
    
    # create default config
    if [ ! -f "$SOUNDSCAPE_CONFIG" ]; then
        cat > "$SOUNDSCAPE_CONFIG" << 'EOF'
{
    "theme": "cyberpunk",
    "volume": 50,
    "events_enabled": true,
    "crossfade": true,
    "loop": true,
    "quality": "high",
    "event_sounds": {
        "notifications": true,
        "alerts": true,
        "transitions": true,
        "interactions": false
    }
}
EOF
    fi
}

# create cyberpunk soundscape
create_cyberpunk_soundscape() {
    local output_file="$SOUNDSCAPE_CACHE/cyberpunk.wav"
    
    echo -e "${BLUE}generating cyberpunk soundscape...${NC}"
    
    # create synthetic cyberpunk sounds using sox (if available)
    if command -v sox >/dev/null 2>&1; then
        # create base ambient track
        sox -n -c 2 synth 300 brownnoise vol 0.3 \
            synth 300 sine 100 vol 0.1 \
            synth 300 sine 150 vol 0.05 \
            synth 300 sine 200 vol 0.05 \
            "$output_file"
        
        # add cyberpunk elements
        sox "$output_file" -n \
            synth 10 sine 800 vol 0.2 \
            synth 5 sine 1200 vol 0.1 \
            synth 3 sine 1600 vol 0.15 \
            "$SOUNDSCAPE_CACHE/cyberpunk_elements.wav"
        
        # mix final track
        sox -m "$output_file" "$SOUNDSCAPE_CACHE/cyberpunk_elements.wav" \
            "$SOUNDSCAPE_CACHE/cyberpunk_final.wav"
        
        mv "$SOUNDSCAPE_CACHE/cyberpunk_final.wav" "$output_file"
        rm "$SOUNDSCAPE_CACHE/cyberpunk_elements.wav"
    else
        # fallback: create placeholder
        echo "cyberpunk soundscape requires sox for generation" > "$output_file.txt"
    fi
}

# create matrix soundscape
create_matrix_soundscape() {
    local output_file="$SOUNDSCAPE_CACHE/matrix.wav"
    
    echo -e "${BLUE}generating matrix soundscape...${NC}"
    
    if command -v sox >/dev/null 2>&1; then
        # matrix rain sounds
        sox -n -c 2 synth 300 brownnoise vol 0.4 \
            synth 300 sine 60 vol 0.1 \
            synth 300 sine 120 vol 0.05 \
            "$output_file"
        
        # add digital elements
        for i in {1..5}; do
            local freq=$((100 + RANDOM % 2000))
            local duration=$((1 + RANDOM % 3))
            
            sox -n synth "$duration" sine "$freq" vol 0.1 \
                "$SOUNDSCAPE_CACHE/matrix_$i.wav"
        done
        
        # mix elements randomly
        sox -m "$output_file" \
            $SOUNDSCAPE_CACHE/matrix_*.wav \
            "$SOUNDSCAPE_CACHE/matrix_final.wav"
        
        mv "$SOUNDSCAPE_CACHE/matrix_final.wav" "$output_file"
        rm "$SOUNDSCAPE_CACHE/matrix_*.wav"
    else
        echo "matrix soundscape requires sox for generation" > "$output_file.txt"
    fi
}

# create nature soundscape
create_nature_soundscape() {
    local output_file="$SOUNDSCAPE_CACHE/nature.wav"
    
    echo -e "${BLUE}generating nature soundscape...${NC}"
    
    if command -v sox >/dev/null 2>&1; then
        # nature ambient sounds
        sox -n -c 2 synth 300 pinknoise vol 0.3 \
            synth 300 sine 440 vol 0.05 \
            synth 300 sine 880 vol 0.03 \
            "$output_file"
        
        # add bird sounds (simplified)
        for i in {1..3}; do
            local freq=$((800 + RANDOM % 800))
            local duration=$((2 + RANDOM % 3))
            
            sox -n synth "$duration" sine "$freq" vol 0.08 \
                "$SOUNDSCAPE_CACHE/nature_$i.wav"
        done
        
        # mix nature sounds
        sox -m "$output_file" \
            $SOUNDSCAPE_CACHE/nature_*.wav \
            "$SOUNDSCAPE_CACHE/nature_final.wav"
        
        mv "$SOUNDSCAPE_CACHE/nature_final.wav" "$output_file"
        rm "$SOUNDSCAPE_CACHE/nature_*.wav"
    else
        echo "nature soundscape requires sox for generation" > "$output_file.txt"
    fi
}

# create space soundscape
create_space_soundscape() {
    local output_file="$SOUNDSCAPE_CACHE/space.wav"
    
    echo -e "${BLUE}generating space soundscape...${NC}"
    
    if command -v sox >/dev/null 2>&1; then
        # space station ambiance
        sox -n -c 2 synth 300 whitenoise vol 0.2 \
            synth 300 sine 40 vol 0.15 \
            synth 300 sine 80 vol 0.1 \
            "$output_file"
        
        # add beeps and boops
        for i in {1..4}; do
            local freq=$((200 + RANDOM % 1000))
            local duration=$((1 + RANDOM % 2))
            
            sox -n synth "$duration" sine "$freq" vol 0.05 \
                "$SOUNDSCAPE_CACHE/space_$i.wav"
        done
        
        # mix space sounds
        sox -m "$output_file" \
            $SOUNDSCAPE_CACHE/space_*.wav \
            "$SOUNDSCAPE_CACHE/space_final.wav"
        
        mv "$SOUNDSCAPE_CACHE/space_final.wav" "$output_file"
        rm "$SOUNDSCAPE_CACHE/space_*.wav"
    else
        echo "space soundscape requires sox for generation" > "$output_file.txt"
    fi
}

# create datacenter soundscape
create_datacenter_soundscape() {
    local output_file="$SOUNDSCAPE_CACHE/datacenter.wav"
    
    echo -e "${BLUE}generating datacenter soundscape...${NC}"
    
    if command -v sox >/dev/null 2>&1; then
        # server room ambiance
        sox -n -c 2 synth 300 brownnoise vol 0.4 \
            synth 300 sine 50 vol 0.2 \
            synth 300 sine 100 vol 0.1 \
            "$output_file"
        
        # add server fan sounds
        for i in {1..3}; do
            local freq=$((60 + RANDOM % 40))
            local duration=10
            
            sox -n synth "$duration" sine "$freq" vol 0.15 \
                "$SOUNDSCAPE_CACHE/datacenter_$i.wav"
        done
        
        # mix datacenter sounds
        sox -m "$output_file" \
            $SOUNDSCAPE_CACHE/datacenter_*.wav \
            "$SOUNDSCAPE_CACHE/datacenter_final.wav"
        
        mv "$SOUNDSCAPE_CACHE/datacenter_final.wav" "$output_file"
        rm "$SOUNDSCAPE_CACHE/datacenter_*.wav"
    else
        echo "datacenter soundscape requires sox for generation" > "$output_file.txt"
    fi
}

# create retro soundscape
create_retro_soundscape() {
    local output_file="$SOUNDSCAPE_CACHE/retro.wav"
    
    echo -e "${BLUE}generating retro soundscape...${NC}"
    
    if command -v sox >/dev/null 2>&1; then
        # retro computer sounds
        sox -n -c 2 synth 300 whitenoise vol 0.2 \
            synth 300 square 440 vol 0.1 \
            synth 300 square 880 vol 0.05 \
            "$output_file"
        
        # add retro beeps
        for i in {1..5}; do
            local freq=$((200 + RANDOM % 600))
            local duration=$((1 + RANDOM % 2))
            
            sox -n synth "$duration" square "$freq" vol 0.08 \
                "$SOUNDSCAPE_CACHE/retro_$i.wav"
        done
        
        # mix retro sounds
        sox -m "$output_file" \
            $SOUNDSCAPE_CACHE/retro_*.wav \
            "$SOUNDSCAPE_CACHE/retro_final.wav"
        
        mv "$SOUNDSCAPE_CACHE/retro_final.wav" "$output_file"
        rm "$SOUNDSCAPE_CACHE/retro_*.wav"
    else
        echo "retro soundscape requires sox for generation" > "$output_file.txt"
    fi
}

# create minimal soundscape
create_minimal_soundscape() {
    local output_file="$SOUNDSCAPE_CACHE/minimal.wav"
    
    echo -e "${BLUE}generating minimal soundscape...${NC}"
    
    if command -v sox >/dev/null 2>&1; then
        # minimal electronic sounds
        sox -n -c 2 synth 300 pinknoise vol 0.2 \
            synth 300 sine 220 vol 0.08 \
            synth 300 sine 440 vol 0.05 \
            "$output_file"
        
        # add minimal elements
        sox -n synth 300 sine 880 vol 0.03 \
            "$SOUNDSCAPE_CACHE/minimal_elements.wav"
        
        # mix minimal sounds
        sox -m "$output_file" \
            "$SOUNDSCAPE_CACHE/minimal_elements.wav" \
            "$SOUNDSCAPE_CACHE/minimal_final.wav"
        
        mv "$SOUNDSCAPE_CACHE/minimal_final.wav" "$output_file"
        rm "$SOUNDSCAPE_CACHE/minimal_elements.wav"
    else
        echo "minimal soundscape requires sox for generation" > "$output_file.txt"
    fi
}

# create rain soundscape
create_rain_soundscape() {
    local output_file="$SOUNDSCAPE_CACHE/rain.wav"
    
    echo -e "${BLUE}generating rain soundscape...${NC}"
    
    if command -v sox >/dev/null 2>&1; then
        # rain sounds
        sox -n -c 2 synth 300 brownnoise vol 0.5 \
            highpass 200 \
            "$output_file"
        
        # add thunder
        for i in {1..2}; do
            local duration=$((2 + RANDOM % 3))
            
            sox -n synth "$duration" sine 40 vol 0.3 \
                "$SOUNDSCAPE_CACHE/rain_$i.wav"
        done
        
        # mix rain sounds
        sox -m "$output_file" \
            $SOUNDSCAPE_CACHE/rain_*.wav \
            "$SOUNDSCAPE_CACHE/rain_final.wav"
        
        mv "$SOUNDSCAPE_CACHE/rain_final.wav" "$output_file"
        rm "$SOUNDSCAPE_CACHE/rain_*.wav"
    else
        echo "rain soundscape requires sox for generation" > "$output_file.txt"
    fi
}

# play soundscape
play_soundscape() {
    local theme="$1"
    local volume="$2"
    
    local soundscape_file="$SOUNDSCAPE_CACHE/$theme.wav"
    
    if [ ! -f "$soundscape_file" ]; then
        echo -e "${RED}error: soundscape file not found${NC}"
        return 1
    fi
    
    # adjust volume
    local volume_factor=$(echo "scale=2; $volume / 100" | bc -l 2>/dev/null || echo "0.5")
    
    # play using available audio player
    if command -v paplay >/dev/null 2>&1; then
        paplay --volume="$volume_factor" "$soundscape_file" --loop &
    elif command -v aplay >/dev/null 2>&1; then
        aplay "$soundscape_file" &
    elif command -v ffplay >/dev/null 2>&1; then
        ffplay -nodisp -loop 0 -volume "$volume" "$soundscape_file" &
    else
        echo -e "${RED}error: no suitable audio player found${NC}"
        echo -e "${CYAN}install pulseaudio-utils or alsa-utils for audio playback${NC}"
        return 1
    fi
}

# generate soundscape
generate_soundscape() {
    local theme="$1"
    
    case "$theme" in
        cyberpunk)
            create_cyberpunk_soundscape
            ;;
        matrix)
            create_matrix_soundscape
            ;;
        nature)
            create_nature_soundscape
            ;;
        space)
            create_space_soundscape
            ;;
        datacenter)
            create_datacenter_soundscape
            ;;
        retro)
            create_retro_soundscape
            ;;
        minimal)
            create_minimal_soundscape
            ;;
        rain)
            create_rain_soundscape
            ;;
        *)
            echo -e "${RED}error: unknown soundscape theme '$theme'${NC}"
            return 1
            ;;
    esac
}

# start soundscape
start_soundscape() {
    local theme=$(jq -r '.theme' "$SOUNDSCAPE_CONFIG" 2>/dev/null || echo "cyberpunk")
    local volume=$(jq -r '.volume' "$SOUNDSCAPE_CONFIG" 2>/dev/null || echo "50")
    
    echo -e "${BLUE}starting soundscape: $theme${NC}"
    
    # generate soundscape if not exists
    if [ ! -f "$SOUNDSCAPE_CACHE/$theme.wav" ]; then
        generate_soundscape "$theme"
    fi
    
    # play soundscape
    play_soundscape "$theme" "$volume"
    
    echo -e "${GREEN}soundscape started${NC}"
    echo -e "${CYAN}press Ctrl+C to stop${NC}"
    
    # wait for user interrupt
    wait
}

# stop soundscape
stop_soundscape() {
    echo -e "${BLUE}stopping soundscape...${NC}"
    
    # kill audio processes
    pkill -f "paplay" 2>/dev/null
    pkill -f "aplay" 2>/dev/null
    pkill -f "ffplay" 2>/dev/null
    
    echo -e "${GREEN}soundscape stopped${NC}"
}

# set soundscape theme
set_theme() {
    local theme="$1"
    
    if [ -z "$theme" ]; then
        echo -e "${RED}error: theme required${NC}"
        return 1
    fi
    
    # update configuration
    local temp_config=$(mktemp)
    jq --arg theme "$theme" '.theme = $theme' "$SOUNDSCAPE_CONFIG" > "$temp_config"
    mv "$temp_config" "$SOUNDSCAPE_CONFIG"
    
    echo -e "${GREEN}soundscape theme set to: $theme${NC}"
    
    # restart if running
    if pgrep -f "milany-soundscape" >/dev/null; then
        stop_soundscape
        sleep 1
        start_soundscape
    fi
}

# set volume
set_volume() {
    local volume="$1"
    
    if [ -z "$volume" ]; then
        echo -e "${RED}error: volume level required (0-100)${NC}"
        return 1
    fi
    
    if [ "$volume" -lt 0 ] || [ "$volume" -gt 100 ]; then
        echo -e "${RED}error: volume must be between 0 and 100${NC}"
        return 1
    fi
    
    # update configuration
    local temp_config=$(mktemp)
    jq --arg volume "$volume" '.volume = ($volume | tonumber)' "$SOUNDSCAPE_CONFIG" > "$temp_config"
    mv "$temp_config" "$SOUNDSCAPE_CONFIG"
    
    echo -e "${GREEN}volume set to: $volume%${NC}"
}

# list available themes
list_themes() {
    echo -e "${CYAN}[ available soundscape themes ]${NC}"
    echo ""
    echo "  cyberpunk   - futuristic electronic ambiance"
    echo "  matrix     - matrix-like digital sounds"
    echo "  nature     - calming natural environment"
    echo "  space      - space station atmosphere"
    echo "  datacenter - server room sounds"
    echo "  retro      - retro computer ambiance"
    echo "  minimal    - minimal electronic sounds"
    echo "  rain       - rain and thunder sounds"
    echo ""
    echo -e "${CYAN}generated themes stored in: $SOUNDSCAPE_CACHE${NC}"
}

# main function
main() {
    init_soundscape
    
    case "${1:-help}" in
        start)
            start_soundscape
            ;;
        stop)
            stop_soundscape
            ;;
        restart)
            stop_soundscape
            sleep 1
            start_soundscape
            ;;
        theme)
            set_theme "$2"
            ;;
        themes)
            list_themes
            ;;
        volume)
            set_volume "$2"
            ;;
        -h|--help)
            show_help
            ;;
        *)
            echo -e "${RED}error: unknown command${NC}"
            show_help
            exit 1
            ;;
    esac
}

# handle signals
trap 'stop_soundscape; exit 0' SIGINT SIGTERM

# run main function
main "$@"
