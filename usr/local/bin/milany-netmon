#!/bin/bash
# milanY network monitor
# advanced network traffic analysis and monitoring

# colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
MAGENTA='\033[0;35m'
WHITE='\033[1;37m'
NC='\033[0m'

# configuration
INTERFACE=""
MODE="realtime"
FILTER=""
LOG_FILE="/var/log/milany-netmon.log"
CAPTURE_FILE=""
DURATION=60

# help function
show_help() {
    echo -e "${CYAN}milany-netmon - network traffic monitor${NC}"
    echo ""
    echo "usage: milany-netmon [options] [mode]"
    echo ""
    echo "modes:"
    echo "  realtime              real-time traffic monitoring (default)"
    echo "  capture               packet capture to file"
    echo "  analyze               analyze existing capture"
    echo "  bandwidth             bandwidth usage monitoring"
    echo "  connections           active connections monitoring"
    echo "  dns                   dns query monitoring"
    echo ""
    echo "options:"
    echo "  -i, --interface <if>  network interface (auto-detect if not specified)"
    echo "  -f, --filter <expr>   tcpdump filter expression"
    echo "  -l, --log <file>      log file (default: $LOG_FILE)"
    echo "  -o, --output <file>    output file for captures"
    echo "  -d, --duration <sec>  monitoring duration (default: 60)"
    echo "  -v, --verbose          verbose output"
    echo "  -h, --help             show this help"
    echo ""
    echo "examples:"
    echo "  milany-netmon realtime -i eth0"
    echo "  milany-netmon capture -o traffic.pcap -d 300"
    echo "  milany-netmon analyze -o traffic.pcap"
    echo "  milany-netmon dns -i wlan0"
}

# detect network interface
detect_interface() {
    if [ -n "$INTERFACE" ]; then
        return
    fi
    
    # try to find the primary interface
    INTERFACE=$(ip route | grep default | head -1 | awk '{print $5}')
    
    if [ -z "$INTERFACE" ]; then
        # fallback to first non-loopback interface
        INTERFACE=$(ip link show | grep -E '^[0-9]+:' | grep -v 'lo:' | head -1 | cut -d: -f2 | tr -d ' ')
    fi
    
    if [ -z "$INTERFACE" ]; then
        echo -e "${RED}error: cannot detect network interface${NC}"
        exit 1
    fi
    
    echo -e "${CYAN}using interface: $INTERFACE${NC}"
}

# check dependencies
check_deps() {
    local missing=()
    
    if ! command -v tcpdump >/dev/null 2>&1; then
        missing+=("tcpdump")
    fi
    
    if ! command -v tshark >/dev/null 2>&1; then
        missing+=("tshark")
    fi
    
    if ! command -v ss >/dev/null 2>&1; then
        missing+=("iproute2")
    fi
    
    if [ ${#missing[@]} -gt 0 ]; then
        echo -e "${RED}error: missing dependencies: ${missing[*]}${NC}"
        echo "install with: pacman -S ${missing[*]}"
        exit 1
    fi
}

# real-time monitoring
realtime_monitor() {
    echo -e "${GREEN}starting real-time monitoring on $INTERFACE${NC}"
    echo -e "${CYAN}press Ctrl+C to stop${NC}"
    echo ""
    
    # setup tcpdump command
    local tcpdump_cmd="tcpdump -i $INTERFACE -n -l"
    
    if [ -n "$FILTER" ]; then
        tcpdump_cmd="$tcpdump_cmd $FILTER"
    fi
    
    # add colors for different protocols
    $tcpdump_cmd | while read line; do
        if echo "$line" | grep -q "GET\|POST"; then
            echo -e "${GREEN}$line${NC}"
        elif echo "$line" | grep -q "DNS"; then
            echo -e "${YELLOW}$line${NC}"
        elif echo "$line" | grep -q "SSH\|TLS\|HTTPS"; then
            echo -e "${BLUE}$line${NC}"
        elif echo "$line" | grep -q "ICMP"; then
            echo -e "${MAGENTA}$line${NC}"
        else
            echo -e "${WHITE}$line${NC}"
        fi
    done
}

# packet capture
packet_capture() {
    if [ -z "$CAPTURE_FILE" ]; then
        CAPTURE_FILE="capture-$(date +%Y%m%d-%H%M%S).pcap"
    fi
    
    echo -e "${GREEN}capturing packets to $CAPTURE_FILE${NC}"
    echo -e "${CYAN}duration: $DURATION seconds${NC}"
    
    local tcpdump_cmd="tcpdump -i $INTERFACE -w $CAPTURE_FILE"
    
    if [ -n "$FILTER" ]; then
        tcpdump_cmd="$tcpdump_cmd $FILTER"
    fi
    
    # run capture for specified duration
    timeout "$DURATION" $tcpdump_cmd
    
    if [ $? -eq 124 ]; then
        echo -e "${YELLOW}capture completed after $DURATION seconds${NC}"
    fi
    
    echo -e "${GREEN}capture saved: $CAPTURE_FILE${NC}"
}

# analyze capture
analyze_capture() {
    if [ ! -f "$CAPTURE_FILE" ]; then
        echo -e "${RED}error: capture file not found${NC}"
        exit 1
    fi
    
    echo -e "${GREEN}analyzing capture: $CAPTURE_FILE${NC}"
    echo ""
    
    # basic statistics
    echo -e "${CYAN}[ BASIC STATISTICS ]${NC}"
    local total_packets=$(tshark -r "$CAPTURE_FILE" -q -z io,stat,0 | grep "frames" | awk '{print $2}')
    local capture_duration=$(tshark -r "$CAPTURE_FILE" -q -z io,stat,0 | grep "Duration" | awk '{print $3}')
    echo -e "${WHITE}total packets:$NC $total_packets"
    echo -e "${WHITE}duration:$NC $capture_duration"
    echo ""
    
    # protocol distribution
    echo -e "${CYAN}[ PROTOCOL DISTRIBUTION ]${NC}"
    tshark -r "$CAPTURE_FILE" -q -z io,phs | head -10
    echo ""
    
    # top talkers
    echo -e "${CYAN}[ TOP TALKERS ]${NC}"
    tshark -r "$CAPTURE_FILE" -q -z conv,ip | head -10
    echo ""
    
    # dns analysis (if any)
    local dns_queries=$(tshark -r "$CAPTURE_FILE" -Y "dns" -T fields -e dns.qry.name 2>/dev/null | wc -l)
    if [ "$dns_queries" -gt 0 ]; then
        echo -e "${CYAN}[ DNS QUERIES ]${NC}"
        echo -e "${WHITE}total queries:$NC $dns_queries"
        echo -e "${WHITE}top domains:${NC}"
        tshark -r "$CAPTURE_FILE" -Y "dns" -T fields -e dns.qry.name 2>/dev/null | sort | uniq -c | sort -nr | head -5
        echo ""
    fi
    
    # http analysis (if any)
    local http_requests=$(tshark -r "$CAPTURE_FILE" -Y "http.request" -T fields -e http.host 2>/dev/null | wc -l)
    if [ "$http_requests" -gt 0 ]; then
        echo -e "${CYAN}[ HTTP REQUESTS ]${NC}"
        echo -e "${WHITE}total requests:$NC $http_requests"
        echo -e "${WHITE}top hosts:${NC}"
        tshark -r "$CAPTURE_FILE" -Y "http.request" -T fields -e http.host 2>/dev/null | sort | uniq -c | sort -nr | head -5
        echo ""
    fi
}

# bandwidth monitoring
bandwidth_monitor() {
    echo -e "${GREEN}monitoring bandwidth on $INTERFACE${NC}"
    echo -e "${CYAN}duration: $DURATION seconds${NC}"
    echo ""
    
    # get initial stats
    local rx_start=$(cat /sys/class/net/$INTERFACE/statistics/rx_bytes)
    local tx_start=$(cat /sys/class/net/$INTERFACE/statistics/tx_bytes)
    
    echo -e "${WHITE}time       rx (mb)    tx (mb)    rx rate     tx rate${NC}"
    echo -e "${WHITE}----       -------    -------    -------     -------${NC}"
    
    local start_time=$(date +%s)
    
    while true; do
        sleep 5
        local current_time=$(date +%s)
        local elapsed=$((current_time - start_time))
        
        if [ $elapsed -ge $DURATION ]; then
            break
        fi
        
        # get current stats
        local rx_current=$(cat /sys/class/net/$INTERFACE/statistics/rx_bytes)
        local tx_current=$(cat /sys/class/net/$INTERFACE/statistics/tx_bytes)
        
        # calculate rates
        local rx_bytes=$((rx_current - rx_start))
        local tx_bytes=$((tx_current - tx_start))
        local rx_rate=$((rx_bytes / 5))
        local tx_rate=$((tx_bytes / 5))
        
        # format output
        local rx_mb=$(echo "scale=2; $rx_bytes / 1048576" | bc 2>/dev/null || echo "0")
        local tx_mb=$(echo "scale=2; $tx_bytes / 1048576" | bc 2>/dev/null || echo "0")
        local rx_rate_mb=$(echo "scale=2; $rx_rate / 1048576" | bc 2>/dev/null || echo "0")
        local tx_rate_mb=$(echo "scale=2; $tx_rate / 1048576" | bc 2>/dev/null || echo "0")
        
        printf "%-10s  %-9s  %-9s  %-9s  %-9s\n" \
            "$(date '+%H:%M:%S')" \
            "$rx_mb" \
            "$tx_mb" \
            "${rx_rate_mb}m/s" \
            "${tx_rate_mb}m/s"
    done
}

# connections monitoring
connections_monitor() {
    echo -e "${GREEN}monitoring active connections${NC}"
    echo ""
    
    while true; do
        clear
        setup_display
        show_header
        
        echo -e "${CYAN}[ ACTIVE CONNECTIONS ]${NC}"
        echo -e "${WHITE}proto  local address          remote address         state${NC}"
        echo -e "${WHITE}-----  ---------------------  ---------------------  --------${NC}"
        
        ss -tuln | grep -v "State" | head -10 | while read line; do
            local proto=$(echo $line | awk '{print $1}')
            local local_addr=$(echo $line | awk '{print $4}')
            local remote_addr=$(echo $line | awk '{print $5}')
            local state=$(echo $line | awk '{print $6}')
            
            printf "%-6s  %-21s  %-21s  %-8s\n" "$proto" "$local_addr" "$remote_addr" "$state"
        done
        
        echo ""
        echo -e "${CYAN}[ ESTABLISHED CONNECTIONS ]${NC}"
        ss -tn state established | wc -l | xargs -I {} echo -e "${WHITE}total established:${NC} {}"
        
        echo ""
        echo -e "${CYAN}[ LISTENING PORTS ]${NC}"
        ss -tuln | grep LISTEN | wc -l | xargs -I {} echo -e "${WHITE}total listening:${NC} {}"
        
        sleep 5
    done
}

# dns monitoring
dns_monitor() {
    echo -e "${GREEN}monitoring dns queries on $INTERFACE${NC}"
    echo -e "${CYAN}press Ctrl+C to stop${NC}"
    echo ""
    
    local tcpdump_cmd="tcpdump -i $INTERFACE -n -l udp port 53"
    
    $tcpdump_cmd | while read line; do
        if echo "$line" | grep -q "A?"; then
            local domain=$(echo "$line" | grep -o "A? [^?]*" | cut -d' ' -f2)
            echo -e "${GREEN}DNS Query:${NC} $domain"
        elif echo "$line" | grep -q "AAAA?"; then
            local domain=$(echo "$line" | grep -o "AAAA? [^?]*" | cut -d' ' -f2)
            echo -e "${BLUE}DNS Query:${NC} $domain (IPv6)"
        fi
    done
}

# header for display
setup_display() {
    echo -e "${MAGENTA}milany network monitor${NC}"
    echo -e "${CYAN}interface: $INTERFACE | mode: $MODE${NC}"
    echo -e "${MAGENTA}$(date '+%Y-%m-%d %H:%M:%S')${NC}"
    echo ""
}

show_header() {
    local width=$(tput cols)
    printf "${MAGENTA}%*s${NC}\n" $width | tr ' ' '='
}

# parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        -i|--interface)
            INTERFACE="$2"
            shift 2
            ;;
        -f|--filter)
            FILTER="$2"
            shift 2
            ;;
        -l|--log)
            LOG_FILE="$2"
            shift 2
            ;;
        -o|--output)
            CAPTURE_FILE="$2"
            shift 2
            ;;
        -d|--duration)
            DURATION="$2"
            shift 2
            ;;
        -v|--verbose)
            set -x
            shift
            ;;
        -h|--help)
            show_help
            exit 0
            ;;
        -*)
            echo -e "${RED}error: unknown option $1${NC}"
            show_help
            exit 1
            ;;
        *)
            MODE="$1"
            shift
            ;;
    esac
done

# main function
main() {
    check_deps
    detect_interface
    
    case "$MODE" in
        realtime)
            realtime_monitor
            ;;
        capture)
            packet_capture
            ;;
        analyze)
            analyze_capture
            ;;
        bandwidth)
            bandwidth_monitor
            ;;
        connections)
            connections_monitor
            ;;
        dns)
            dns_monitor
            ;;
        *)
            echo -e "${RED}error: unknown mode '$MODE'${NC}"
            show_help
            exit 1
            ;;
    esac
}

# handle signals
trap 'echo -e "\n${YELLOW}monitoring stopped${NC}"; exit 0' SIGINT SIGTERM

# run main function
main "$@"
