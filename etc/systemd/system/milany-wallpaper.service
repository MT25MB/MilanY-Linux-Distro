[Unit]
Description=milanY Live Wallpaper Service
After=graphical.target
Wants=graphical.target

[Service]
Type=simple
User=%i
Restart=always
RestartSec=5
Environment=DISPLAY=:0
ExecStart=/usr/local/bin/milany-wallpaper
ExecReload=/bin/kill -HUP $MAINPID
KillMode=mixed
TimeoutStopSec=5

[Install]
WantedBy=graphical.target
